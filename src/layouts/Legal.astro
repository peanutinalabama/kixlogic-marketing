---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  effectiveDate?: string;
}

const { title, description, effectiveDate = 'April 2, 2026' } = Astro.props;
---
<Base title={title} description={description}>
  <section class="legal-page section">
    <div class="container legal-inner">
      <header class="legal-header">
        <a href="/" class="breadcrumb">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8 3L4 7l4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Kixlogic
        </a>
        <h1>{title}</h1>
        <p class="legal-meta">
          <strong>Effective:</strong> {effectiveDate} &nbsp;·&nbsp;
          Questions? <a href="mailto:support@kixlogic.com">support@kixlogic.com</a>
        </p>
      </header>
      <article class="legal-prose">
        <slot />
      </article>
    </div>
  </section>
</Base>

<style>
.legal-page { padding-top: 2rem; }
.legal-inner { max-width: 800px; margin: 0 auto; }
.legal-header { margin-bottom: 2.5rem; }
.legal-header .breadcrumb {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}
.legal-header .breadcrumb:hover { color: var(--gold); }
.legal-header h1 {
  font-size: clamp(2rem, 4vw, 2.75rem);
  font-weight: 600;
  letter-spacing: -0.025em;
  margin-bottom: 0.75rem;
}
.legal-meta { font-size: 0.85rem; color: var(--text-dim); }
.legal-meta a { color: var(--gold); font-weight: 600; }

:global(.legal-prose h2) {
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--text);
  margin: 2.25rem 0 0.75rem;
  padding-top: 0.5rem;
  border-top: 1px solid var(--border);
}
:global(.legal-prose h2:first-of-type) { border-top: none; margin-top: 0; padding-top: 0; }
:global(.legal-prose h3) {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  margin: 1.25rem 0 0.5rem;
}
:global(.legal-prose p) {
  font-size: 0.925rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 1rem;
}
:global(.legal-prose ul),
:global(.legal-prose ol) {
  margin: 0.5rem 0 1rem 1.5rem;
  font-size: 0.925rem;
  color: var(--text-muted);
  line-height: 1.7;
}
:global(.legal-prose li) { margin-bottom: 0.4rem; }
:global(.legal-prose a) { color: var(--gold); font-weight: 500; }
:global(.legal-prose a:hover) { color: var(--gold-light); }
:global(.legal-prose strong) { color: var(--text); }
:global(.legal-prose .callout) {
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  margin: 1.5rem 0;
  font-size: 0.875rem;
  color: var(--text-muted);
}
:global(.legal-prose table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0 1.5rem;
  font-size: 0.85rem;
}
:global(.legal-prose th) {
  background: var(--surface-2);
  padding: 0.65rem 0.85rem;
  text-align: left;
  font-weight: 600;
  color: var(--text);
  border: 1px solid var(--border);
}
:global(.legal-prose td) {
  padding: 0.65rem 0.85rem;
  border: 1px solid var(--border);
  color: var(--text-muted);
  vertical-align: top;
}
</style>
