---
import Base from '../layouts/Base.astro';

const cards = [
  {
    icon: '🎯',
    title: 'Built for the real world',
    text: 'Our products are developed in the field — built for and tested by real businesses. Not designed in a vacuum by people who\'ve never run a team, managed a hiring process, or tried to grow a client base.',
  },
  {
    icon: '🤖',
    title: 'AI that earns its keep',
    text: 'We use AI where it actually saves time — scoring resumes against job requirements, writing job descriptions in seconds, and surfacing hiring insights automatically. Not as a marketing checkbox.',
  },
  {
    icon: '⚡',
    title: 'Live today, not next quarter',
    text: 'Every product we ship is designed to be running the same day you sign up. No implementation projects, no onboarding calls, no migration timelines. You\'re live in minutes.',
  },
  {
    icon: '🔗',
    title: 'A growing product suite',
    text: 'Kixlogic ATS is our flagship product — and the starting point for a suite of practical tools for small businesses. Every product we add will solve a specific, real problem that existing platforms either ignore or overcharge for.',
  },
];
---
<Base
  title="About"
  description="Kixlogic, LLC builds practical, affordable software for small and mid-sized businesses — starting with Kixlogic ATS."
>
  <section class="about-hero">
    <div class="container">
      <span class="section-tag">✦ Our story</span>
      <h1 class="section-title">Built by people who felt the pain</h1>
      <p class="about-lead">
        Kixlogic, LLC was built on a simple belief — small and mid-sized businesses deserve great software. Not watered-down enterprise tools, not overpriced platforms built for companies with IT departments. Software that works the day you sign up, at a price that makes sense.
      </p>
    </div>
  </section>

  <section class="mission-block">
    <div class="container">
      <blockquote class="mission-quote">
        "Every small business deserves software built for them — not a stripped-down version of what enterprise pays <span class="highlight">$50,000 a year</span> for."
      </blockquote>
      <p class="mission-attribution">— The Kixlogic Mission</p>
    </div>
  </section>

  <section class="about-cards section">
    <div class="container about-grid">
      {cards.map(c => (
        <div class="about-card">
          <div class="about-card-icon">{c.icon}</div>
          <div class="about-card-title">{c.title}</div>
          <div class="about-card-text">{c.text}</div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
.about-hero {
  text-align: center;
  padding: 5rem 0 3rem;
  max-width: 800px;
  margin: 0 auto;
}
.section-tag {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.25rem;
}
.section-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.15;
  letter-spacing: -1px;
  margin-bottom: 1rem;
}
.about-lead {
  font-size: 1.05rem;
  color: var(--text-muted);
  line-height: 1.75;
}
.mission-block {
  text-align: center;
  padding: 0 0 5rem;
}
.mission-quote {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: clamp(1.25rem, 3vw, 2rem);
  line-height: 1.4;
  max-width: 700px;
  margin: 0 auto 1rem;
  border: none;
}
.mission-quote .highlight { color: var(--gold); }
.mission-attribution { font-size: 0.875rem; color: var(--text-dim); }
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  padding-bottom: 5rem;
}
.about-card {
  padding: 2rem;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 1px solid var(--border);
}
.about-card-icon { font-size: 2rem; margin-bottom: 1rem; }
.about-card-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: 0.6rem;
}
.about-card-text { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }

@media (max-width: 700px) {
  .about-grid { grid-template-columns: 1fr; }
}
</style>
