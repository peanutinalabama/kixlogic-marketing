---
import Base from '../layouts/Base.astro';
---
<Base
  title="Kixlogic CMP"
  description="Kixlogic CMP — compensation intelligence from market rates to payday. Market benchmarks, merit cycles, pay equity, and commission tracking for teams under 500."
>
  <section class="cmp-hero">
    <div class="container cmp-hero-inner">
      <div class="cmp-hero-copy">
        <span class="cmp-eyebrow">Kixlogic CMP</span>
        <h1>
          Compensation intelligence from market rates to <span class="cmp-accent">payday.</span>
        </h1>
        <p>
          Market benchmarks, merit cycles, pay equity, and commission tracking — one platform for hiring, budgeting, and showing every dollar earned.
        </p>
        <div class="cmp-hero-actions">
          <a href="/contact/" class="btn btn-cmp-primary">Get notified at launch →</a>
          <a href="https://app.kixlogic.com/dashboard" class="btn btn-cmp-outline">Sign in</a>
        </div>
      </div>
      <div class="cmp-analyze-card" aria-hidden="true">
        <h2>Analyze a role</h2>
        <p class="cmp-field-label">Compensation model</p>
        <div class="cmp-models">
          <span class="cmp-model active">🌐 General</span>
          <span class="cmp-model">📋 Healthcare</span>
          <span class="cmp-model">🔵 Insurance</span>
          <span class="cmp-model">💼 Sales</span>
          <span class="cmp-model">🏠 Real Estate</span>
          <span class="cmp-model">🍽️ Restaurants</span>
        </div>
        <label class="cmp-field-label">Job title</label>
        <div class="cmp-input">e.g. Marketing Manager, Software Engineer</div>
        <div class="cmp-row">
          <div>
            <label class="cmp-field-label">City</label>
            <div class="cmp-input">e.g. Chicago</div>
          </div>
          <div>
            <label class="cmp-field-label">State</label>
            <div class="cmp-input">Select state</div>
          </div>
        </div>
        <div class="cmp-row">
          <div>
            <label class="cmp-field-label">Experience</label>
            <div class="cmp-input filled">3–5 years</div>
          </div>
          <div>
            <label class="cmp-field-label">Company size</label>
            <div class="cmp-input filled">11–50 employees</div>
          </div>
        </div>
        <button class="cmp-cta-mock">Try it free →</button>
      </div>
    </div>
  </section>

  <section class="section" id="cmp-features">
    <div class="container">
      <span class="feat-section-tag">✦ Full feature breakdown</span>
      <h2 class="feat-section-title">Everything Kixlogic CMP can do</h2>
      <p class="feat-section-sub">One platform for market benchmarks, merit cycles, pay equity, and commission tracking — launching inside the Kixlogic Workforce Intelligence Platform.</p>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <div class="feature-title">Role-Based Market Benchmarks</div>
          <div class="feature-desc">Blend job postings, career sites, and BLS data into role-specific pay ranges. Benchmark any position by job title, city, state, and years of experience — low, median, and high figures you can defend.</div>
          <div class="feature-tag tag-data">Market Data</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🏭</div>
          <div class="feature-title">Industry Compensation Models</div>
          <div class="feature-desc">Six purpose-built models — General, Healthcare, Insurance, Sales, Real Estate, and Restaurants — so benchmarks reflect how each industry actually pays, not a one-size-fits-all average.</div>
          <div class="feature-tag tag-data">Market Data</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔍</div>
          <div class="feature-title">Analyze Any Role in Seconds</div>
          <div class="feature-desc">Enter a job title, location, experience level, and company size — get a complete compensation picture instantly. No spreadsheet wrangling, no stale survey data.</div>
          <div class="feature-tag tag-data">Market Data</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📈</div>
          <div class="feature-title">Merit Cycle Planning</div>
          <div class="feature-desc">Plan annual increases with budget guardrails and manager-ready recommendations before payroll runs. Every dollar allocated on purpose instead of by gut feel.</div>
          <div class="feature-tag tag-planning">Planning</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎯</div>
          <div class="feature-title">Offer Competitiveness Scoring</div>
          <div class="feature-desc">Score offers against the market in real time — see whether a package is below, at, or above market before it goes out. Give recruiters and managers confidence at the offer stage.</div>
          <div class="feature-tag tag-planning">Planning</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚖️</div>
          <div class="feature-title">Pay Equity Analysis</div>
          <div class="feature-desc">Surface pay gaps by gender, department, and tenure. Spot compression early and fix it before it becomes a retention risk — or a legal one.</div>
          <div class="feature-tag tag-equity">Pay Equity</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <div class="feature-title">Commission Tracking</div>
          <div class="feature-desc">Track commission-based earnings alongside base pay so every dollar earned is visible — one ledger for hiring, budgeting, and showing employees exactly what payday looks like.</div>
          <div class="feature-tag tag-earnings">Earnings</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🤝</div>
          <div class="feature-title">Built to Pair With Kixlogic ATS</div>
          <div class="feature-desc">Compensation intelligence inside the hiring workflow — benchmark the role when you post it, score the package when you make the offer. Hiring and pay decisions in one platform.</div>
          <div class="feature-tag tag-platform">Platform</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-grey">
    <div class="container cmp-cta-band">
      <div>
        <span class="section-tag">Coming soon</span>
        <h2>Kixlogic CMP launches inside the Workforce Intelligence Platform</h2>
        <p>Pair compensation intelligence with Kixlogic ATS so hiring and pay decisions stay in one workflow.</p>
      </div>
      <div class="cmp-cta-buttons">
        <a href="/ats/" class="btn btn-primary">Explore Kixlogic ATS</a>
        <a href="/contact/" class="btn btn-outline">Talk to us</a>
      </div>
    </div>
  </section>
</Base>

<style>
.cmp-hero {
  background: linear-gradient(160deg, #0b1f3f 0%, #102a54 55%, #0d2244 100%);
  color: #fff;
  padding: 3.5rem 0 4rem;
}
.cmp-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2.5rem;
  align-items: center;
}
.cmp-eyebrow {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #7ee0b8;
  margin-bottom: 1rem;
}
.cmp-hero-copy h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 600;
  line-height: 1.15;
  margin-bottom: 1rem;
}
.cmp-accent { color: #1db980; }
.cmp-hero-copy p {
  font-size: 1rem;
  line-height: 1.65;
  color: rgba(255,255,255,0.82);
  max-width: 520px;
  margin-bottom: 1.5rem;
}
.cmp-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.btn-cmp-primary {
  background: #1db980;
  color: #fff;
  border: none;
  padding: 0.7rem 1.25rem;
  border-radius: var(--radius);
  font-weight: 600;
  font-size: 0.9375rem;
}
.btn-cmp-primary:hover { background: #17a06d; }
.btn-cmp-outline {
  border: 1px solid rgba(255,255,255,0.35);
  color: #fff;
  padding: 0.7rem 1.25rem;
  border-radius: var(--radius);
  font-weight: 600;
  font-size: 0.9375rem;
}
.btn-cmp-outline:hover { border-color: #fff; }

.cmp-analyze-card {
  background: #fff;
  color: var(--text);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  box-shadow: 0 20px 50px rgba(0,0,0,0.25);
}
.cmp-analyze-card h2 {
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 1rem;
}
.cmp-field-label {
  display: block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.35rem;
}
.cmp-models { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
.cmp-model {
  padding: 0.35rem 0.85rem;
  border-radius: var(--radius-pill);
  background: #f3f4f6;
  color: var(--text-muted);
  font-size: 0.75rem;
  font-weight: 600;
}
.cmp-model.active { background: #d7f5e8; color: #0f6b4d; }
.cmp-input {
  border: 1px solid var(--border);
  background: #f9fafb;
  border-radius: 8px;
  padding: 0.65rem 0.75rem;
  font-size: 0.8125rem;
  color: #9ca3af;
  margin-bottom: 0.85rem;
}
.cmp-input.filled { color: var(--text); }
.cmp-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}
.cmp-cta-mock {
  margin-top: 0.5rem;
  background: #1db980;
  color: #fff;
  text-align: center;
  font-weight: 600;
  padding: 0.8rem;
  border-radius: 10px;
}

.feat-section-tag {
  display: inline-flex;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.25rem;
}
.feat-section-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: -1px;
  margin-bottom: 1rem;
}
.feat-section-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 1rem;
}
.feature-card {
  padding: 1.75rem;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 1px solid var(--border);
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}
.feature-card:hover {
  border-color: var(--border-gold);
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
}
.feature-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  margin-bottom: 1.1rem;
}
.feature-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 0.5rem;
}
.feature-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; }
.feature-tag {
  display: inline-block;
  margin-top: 0.85rem;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
}
.tag-data     { background: rgba(20,184,148,0.12); color: #14B894; }
.tag-planning { background: rgba(59,130,246,0.12); color: #3b82f6; }
.tag-equity   { background: rgba(139,92,246,0.12); color: #8b5cf6; }
.tag-earnings { background: rgba(202,80,16,0.12);  color: #ca5010; }
.tag-platform { background: rgba(10,95,117,0.12);  color: #0A5F75; }

.cmp-cta-band {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}
.section-tag {
  display: inline-flex;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: #fff4ce;
  border: 1px solid #fde7a0;
  font-size: 0.75rem;
  font-weight: 700;
  color: #ca5010;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 0.75rem;
}
.cmp-cta-band h2 {
  font-size: clamp(1.35rem, 3vw, 1.75rem);
  font-weight: 600;
  margin-bottom: 0.5rem;
}
.cmp-cta-band p { color: var(--text-muted); max-width: 520px; }
.cmp-cta-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; }

@media (max-width: 900px) {
  .cmp-hero-inner { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .features-grid { grid-template-columns: 1fr; }
}
</style>
