---
import Base from '../layouts/Base.astro';
---
<Base
  title="Renumify"
  description="Renumify — compensation intelligence from Kixlogic. Blended market rates from job postings, career sites, and BLS data. Coming soon."
>
  <section class="section coming-soon">
    <div class="container text-center">
      <div class="product-icon">📊</div>
      <span class="section-tag">Coming Soon</span>
      <h1 class="section-title">Renumify</h1>
      <p class="product-tagline">Compensation Intelligence</p>
      <p class="section-sub mx-auto">
        Blended market rates from job postings, company career sites, and BLS data. Start with a general all-purpose model, then upgrade to industry-specific models for Healthcare, Insurance, Sales, Real Estate, and Restaurants.
      </p>
      <div class="badges">
        <span class="badge badge-soon">Coming Soon</span>
        <span class="badge badge-indigo">AI-Powered</span>
      </div>
      <p style="margin-top:2rem">
        <a href="/" class="btn btn-outline">← Back to Kixlogic</a>
        <a href="/ats/" class="btn btn-primary" style="margin-left:0.75rem">Explore Kixlogic ATS →</a>
      </p>
    </div>
  </section>
</Base>

<style>
.coming-soon { padding: 6rem 0; min-height: 60vh; display: flex; align-items: center; }
.text-center { text-align: center; }
.product-icon {
  width: 72px; height: 72px;
  border-radius: 18px;
  background: var(--indigo-dim);
  border: 1px solid rgba(99,102,241,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  margin: 0 auto 1.5rem;
}
.section-tag {
  display: inline-flex;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.25rem;
}
.section-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  margin-bottom: 0.5rem;
}
.product-tagline {
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--indigo-light);
  margin-bottom: 1.5rem;
}
.section-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 1.5rem;
}
.mx-auto { margin-left: auto; margin-right: auto; }
.badges { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
.badge {
  padding: 0.2rem 0.65rem;
  border-radius: 99px;
  font-size: 0.7rem;
  font-weight: 700;
}
.badge-soon { background: rgba(245,158,11,0.12); color: #F59E0B; border: 1px solid rgba(245,158,11,0.28); }
.badge-indigo { background: var(--indigo-dim); color: var(--indigo-light); border: 1px solid rgba(99,102,241,0.3); }
</style>
