---
import Base from '../layouts/Base.astro';

const quickNav = [
  { href: '/ats/', icon: '💼', label: 'Shop ATS' },
  { href: '/pricing/', icon: '💳', label: 'See pricing' },
  { href: '/contact/', icon: '📧', label: 'Contact us' },
  { href: 'https://app.kixlogic.com/dashboard', icon: '🔐', label: 'Sign in' },
  { href: '/support/', icon: '🛟', label: 'Get support' },
  { href: '/sales-partner/', icon: '🤝', label: 'Partners' },
];

const products = [
  {
    href: '/ats/',
    img: '/images/dashboard.png',
    title: 'Kixlogic ATS',
    desc: 'AI resume scoring, white-label careers pages, and advanced analytics — without the enterprise price tag.',
    cta: 'Explore Kixlogic ATS',
  },
  {
    href: '/pricing/',
    img: '/images/pipeline.png',
    title: 'Plans & pricing',
    desc: 'Four plans from $49/month. Growth and Professional include a 14-day free trial.',
    cta: 'Compare plans',
  },
  {
    href: '/contact/',
    img: '/og-default.png',
    title: 'Talk to our team',
    desc: 'Questions about setup, demos, or partnerships? We respond within one business day.',
    cta: 'Contact us',
  },
  {
    href: '/comp/',
    img: '/og-default.png',
    title: 'Renumify',
    desc: 'Compensation intelligence with blended market rates. Industry-specific models coming soon.',
    cta: 'Learn more',
    soon: true,
  },
];

const aiCards = [
  {
    title: 'AI resume scoring',
    desc: 'Every applicant gets an instant match score against your job requirements — stars, percentage, and missing skills in seconds.',
    href: '/ats/#ats-features',
  },
  {
    title: 'AI job descriptions',
    desc: 'Type a job title, pick your industry, and get a complete professional posting ready to edit and publish.',
    href: '/ats/#ats-features',
  },
  {
    title: 'Compensation intelligence',
    desc: 'Renumify blends job postings, career sites, and BLS data into actionable pay benchmarks. Coming soon.',
    href: '/comp/',
  },
];

const why = [
  { title: 'Built for teams under 500', desc: 'Not enterprise software with a small-business skin. Designed from scratch for practical hiring teams.' },
  { title: 'AI that earns its keep', desc: 'Resume scoring, JD writing, and setup assistance that solve real problems — not marketing checkboxes.' },
  { title: 'Live in minutes', desc: '100% cloud SaaS. Sign up, brand your careers page, and start hiring the same day. No IT project required.' },
];
---
<Base
  title="Kixlogic Workforce Intelligence Platform"
  description="Kixlogic Workforce Intelligence Platform — practical, affordable workforce software for teams under 500. ATS, compensation intelligence, and more."
>
  <!-- Greeting hero (Microsoft-style) -->
  <section class="ms-greeting">
    <div class="container greeting-inner">
      <h1>Hi there, welcome to Kixlogic</h1>
      <p class="greeting-sub">Kixlogic Workforce Intelligence Platform</p>

      <div class="segment-toggle" role="tablist">
        <button type="button" class="segment active" data-segment="business">For business</button>
        <button type="button" class="segment" data-segment="personal">For hiring teams</button>
      </div>

      <div class="greeting-actions">
        <a href="/ats/" class="btn btn-outline">Start free trial</a>
        <a href="/pricing/" class="btn btn-outline">Compare plans</a>
        <a href="/contact/" class="btn btn-outline">Talk to us</a>
      </div>
    </div>
  </section>

  <!-- Hero carousel card -->
  <section class="ms-hero-card">
    <div class="container">
      <div class="hero-card">
        <div class="hero-card-copy">
          <h2>Hire smarter. Your way.</h2>
          <p>Kixlogic ATS is built for small and mid-sized businesses. Launch in 10 minutes — AI resume scoring, analytics, white-label careers pages, and more.</p>
          <button type="button" class="btn btn-primary" data-checkout="growth">Start free trial</button>
        </div>
        <div class="hero-card-visual">
          <img src="/images/dashboard.png" alt="Kixlogic ATS dashboard" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- Icon quick nav -->
  <section class="ms-quicknav section-sm">
    <div class="container">
      <div class="quicknav-grid">
        {quickNav.map(q => (
          <a href={q.href} class="quicknav-item">
            <span class="quicknav-icon">{q.icon}</span>
            <span class="quicknav-label">{q.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Product grid (4 columns) -->
  <section class="section" id="products">
    <div class="container">
      <div class="products-grid">
        {products.map(p => (
          <a href={p.href} class="ms-card">
            <img src={p.img} alt="" class="ms-card-img" loading="lazy" />
            <div class="ms-card-body">
              <h3 class="ms-card-title">
                {p.title}
                {p.soon && <span class="soon-badge">Soon</span>}
              </h3>
              <p class="ms-card-desc">{p.desc}</p>
              <span class="ms-card-cta">{p.cta} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Large feature banner -->
  <section class="section section-grey">
    <div class="container">
      <div class="feature-banner">
        <div class="feature-banner-copy">
          <h2>Pipeline management built for real hiring teams</h2>
          <p>Drag-and-drop kanban, AI scoring, interview scheduling, offer letters, and 90+ customizable application questions — all in one cloud platform.</p>
          <a href="/ats/" class="btn btn-primary">Explore Kixlogic ATS</a>
        </div>
        <div class="feature-banner-img">
          <img src="/images/pipeline.png" alt="Kixlogic candidate pipeline" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Get to know AI -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">Get to know Kixlogic AI</h2>
      <div class="ai-grid">
        {aiCards.map(c => (
          <a href={c.href} class="ms-card ai-card">
            <div class="ms-card-body">
              <h3 class="ms-card-title">{c.title}</h3>
              <p class="ms-card-desc">{c.desc}</p>
              <span class="ms-card-cta">Learn more →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Kixlogic -->
  <section class="section section-grey">
    <div class="container">
      <h2 class="section-heading">Why teams choose Kixlogic</h2>
      <div class="why-grid">
        {why.map(w => (
          <div class="why-card">
            <h3>{w.title}</h3>
            <p>{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
document.querySelectorAll('.segment').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.segment').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });
});
</script>

<style>
/* Greeting */
.ms-greeting {
  padding: 2.5rem 0 1.5rem;
  text-align: center;
}
.greeting-inner h1 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 0.35rem;
}
.greeting-sub {
  font-size: 0.9375rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}
.segment-toggle {
  display: inline-flex;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px;
  margin-bottom: 1.25rem;
}
.segment {
  padding: 0.4rem 1.25rem;
  border: none;
  background: transparent;
  border-radius: var(--radius-pill);
  font-family: inherit;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
  transition: background var(--transition), color var(--transition);
}
.segment.active {
  background: #fff;
  color: var(--text);
  box-shadow: var(--shadow-card);
}
.greeting-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}

/* Hero card */
.ms-hero-card { padding-bottom: 1rem; }
.hero-card {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 0;
  background: var(--navy-2);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 360px;
}
.hero-card-copy {
  padding: 3rem 3rem 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}
.hero-card-copy h2 {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 0.75rem;
}
.hero-card-copy p {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 420px;
}
.hero-card-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 1rem;
}
.hero-card-visual img {
  width: 100%;
  height: auto;
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}

/* Quick nav */
.quicknav-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.5rem;
  text-align: center;
}
.quicknav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 0.5rem;
  border-radius: var(--radius-lg);
  transition: background var(--transition);
}
.quicknav-item:hover { background: var(--navy-2); }
.quicknav-icon { font-size: 1.5rem; }
.quicknav-label {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text);
}

/* Product grid */
.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
}
.soon-badge {
  font-size: 0.65rem;
  font-weight: 700;
  color: #ca5010;
  background: #fff4ce;
  padding: 0.1rem 0.45rem;
  border-radius: var(--radius-pill);
  margin-left: 0.35rem;
  vertical-align: middle;
}

/* Feature banner */
.feature-banner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 3rem;
  align-items: center;
  padding: 2rem 0;
}
.feature-banner-copy h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 600;
  margin-bottom: 0.75rem;
}
.feature-banner-copy p {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 480px;
}
.feature-banner-img img {
  width: 100%;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-hover);
}

/* AI section */
.section-heading {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
}
.ai-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}
.ai-card { border: 1px solid var(--border); border-radius: var(--radius-lg); }

/* Why */
.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.why-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
}
.why-card h3 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}
.why-card p {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.55;
}

@media (max-width: 1100px) {
  .products-grid { grid-template-columns: repeat(2, 1fr); }
  .quicknav-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .hero-card { grid-template-columns: 1fr; }
  .hero-card-visual { order: -1; min-height: 200px; }
  .hero-card-copy { padding: 2rem 1.5rem; }
  .feature-banner { grid-template-columns: 1fr; }
  .ai-grid, .why-grid { grid-template-columns: 1fr; }
  .products-grid { grid-template-columns: 1fr; }
  .quicknav-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
