---
import Base from '../layouts/Base.astro';

const why = [
  {
    icon: '🎯',
    title: 'Built for small business',
    desc: "We don't build enterprise software with a small-business skin. Every product is designed from the ground up for teams under 500 — simpler, faster, and priced to match.",
  },
  {
    icon: '🤖',
    title: 'AI that earns its keep',
    desc: 'Our AI features solve real problems — scoring resumes, identifying at-risk clients, writing job descriptions. Not checkbox features added for marketing copy.',
  },
  {
    icon: '⚡',
    title: 'Live in minutes, not months',
    desc: 'No implementation projects. No consultants. No migration calls. Kixlogic is 100% SaaS, running entirely in the cloud. Every product we build is designed to be running and delivering value the same day you sign up.',
  },
];
---
<Base
  title="Kixlogic — Small Business Software"
  description="Kixlogic builds practical, affordable software for small and mid-sized businesses — including Kixlogic ATS, an AI-powered applicant tracking system built for teams under 500."
>
  <section class="home-hero">
    <div class="container home-hero-inner">
      <img src="/Kixlogo-light.png" alt="Kixlogic" class="home-logo" width="320" height="94" />
      <div class="hero-eyebrow">✦ Kixlogic, LLC &nbsp;·&nbsp; Small business software</div>
      <h1 class="hero-title">
        Software built for the way<br />
        <span class="line-2">you actually work.</span>
      </h1>
      <p class="hero-sub">
        We make practical, affordable apps for small and mid-sized businesses. No enterprise complexity, no enterprise price tags — just tools that get out of your way.
      </p>
      <a href="#products" class="btn btn-outline btn-lg">See Our Products ↓</a>
    </div>
  </section>

  <section class="section" id="products">
    <div class="container">
      <div class="text-center">
        <span class="section-tag">✦ Our products</span>
      </div>
      <h2 class="section-title text-center">Practical software for small businesses.</h2>
      <p class="section-sub text-center mx-auto">
        Not retrofitted from enterprise platforms. Designed from scratch for teams under 500.
      </p>

      <div class="products-grid">
        <a href="/ats/" class="product-card product-card-teal">
          <div class="product-icon product-icon-teal">💼</div>
          <div class="product-name">Kixlogic ATS</div>
          <div class="product-tagline product-tagline-teal">Intelligent Applicant Tracking</div>
          <p class="product-desc">
            AI resume scoring, white-label careers pages, advanced analytics — without the enterprise price tag. Post jobs, manage your pipeline, and hire smarter starting today.
          </p>
          <div class="product-badges">
            <span class="badge badge-teal">AI-Powered</span>
            <span class="badge badge-neutral">14-day free trial</span>
          </div>
          <span class="product-cta product-cta-teal">Explore Kixlogic ATS →</span>
        </a>

        <div class="product-card product-card-indigo product-card-soon">
          <div class="product-icon product-icon-indigo">📊</div>
          <div class="product-name">Renumify</div>
          <div class="product-tagline product-tagline-indigo">Compensation Intelligence</div>
          <p class="product-desc">
            Blended market rates from job postings, company career sites, and BLS data. Start with a general all-purpose model, then upgrade to industry-specific models for Healthcare, Insurance, Sales, Real Estate, and Restaurants.
          </p>
          <div class="product-badges">
            <span class="badge badge-soon">Coming Soon</span>
            <span class="badge badge-indigo">AI-Powered</span>
          </div>
          <span class="product-cta product-cta-soon">Coming soon →</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section why-section">
    <div class="container">
      <div class="text-center">
        <span class="section-tag">✦ Why Kixlogic</span>
      </div>
      <h2 class="section-title text-center">The way we build is different.</h2>
      <div class="why-grid">
        {why.map(w => (
          <div class="why-card">
            <div class="why-icon">{w.icon}</div>
            <div class="why-title">{w.title}</div>
            <div class="why-desc">{w.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
.home-hero {
  padding: 5rem 0 3rem;
  min-height: 55vh;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}
.home-hero-inner {
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}
.home-logo {
  height: 94px;
  width: auto;
  margin: 0 auto 2rem;
  display: block;
}
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 1rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.5rem;
}
.hero-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2.25rem, 5vw, 3.75rem);
  line-height: 1.1;
  letter-spacing: -1.5px;
  margin-bottom: 1.25rem;
}
.line-2 {
  background: linear-gradient(135deg, var(--gold), var(--gold-light), #fff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  font-size: 1.1rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 2rem;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
}
.btn-lg { padding: 0.95rem 2.25rem; font-size: 1rem; border-radius: 12px; }

.section-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.25rem;
}
.section-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.15;
  letter-spacing: -1px;
  margin-bottom: 0.75rem;
}
.section-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}
.text-center { text-align: center; }
.mx-auto { margin-left: auto; margin-right: auto; }

.products-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  max-width: 960px;
  margin: 0 auto;
}
.product-card {
  padding: 2.25rem;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 1px solid var(--border);
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
}
.product-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity var(--transition);
}
.product-card-teal::before { background: linear-gradient(135deg, var(--gold-dim), transparent 65%); }
.product-card-indigo::before { background: linear-gradient(135deg, var(--indigo-dim), transparent 65%); }
.product-card-teal:hover { transform: translateY(-4px); box-shadow: 0 24px 50px rgba(0,0,0,0.35); border-color: var(--border-gold); }
.product-card-indigo:hover { border-color: rgba(99,102,241,0.3); }
.product-card-teal:hover::before, .product-card-indigo:hover::before { opacity: 1; }
.product-card-soon { cursor: default; }
.product-card-soon:hover { transform: none; box-shadow: none; }
.product-card-soon:hover::before { opacity: 0; }
.product-icon {
  width: 54px; height: 54px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  margin-bottom: 1.2rem;
  position: relative;
  z-index: 1;
}
.product-icon-teal { background: var(--gold-dim); border: 1px solid var(--border-gold); }
.product-icon-indigo { background: var(--indigo-dim); border: 1px solid rgba(99,102,241,0.3); }
.product-name {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.45rem;
  margin-bottom: 0.2rem;
  position: relative;
  z-index: 1;
}
.product-tagline {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 1rem;
  position: relative;
  z-index: 1;
}
.product-tagline-teal { color: var(--gold); }
.product-tagline-indigo { color: var(--indigo-light); }
.product-desc {
  font-size: 0.925rem;
  color: var(--text-muted);
  line-height: 1.72;
  margin-bottom: 1.4rem;
  flex: 1;
  position: relative;
  z-index: 1;
}
.product-badges {
  display: flex;
  gap: 0.45rem;
  flex-wrap: wrap;
  margin-bottom: 1.6rem;
  position: relative;
  z-index: 1;
}
.badge {
  padding: 0.2rem 0.65rem;
  border-radius: 99px;
  font-size: 0.7rem;
  font-weight: 700;
}
.badge-teal { background: var(--gold-dim); color: var(--gold); border: 1px solid var(--border-gold); }
.badge-indigo { background: var(--indigo-dim); color: var(--indigo-light); border: 1px solid rgba(99,102,241,0.3); }
.badge-neutral { background: var(--surface-2); color: var(--text-muted); border: 1px solid var(--border); }
.badge-soon { background: rgba(245,158,11,0.12); color: #F59E0B; border: 1px solid rgba(245,158,11,0.28); }
.product-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  position: relative;
  z-index: 1;
}
.product-cta-teal { color: var(--gold); }
.product-cta-indigo { color: var(--indigo-light); }
.product-cta-soon { color: var(--text-dim); }

.why-section { padding-top: 1rem; padding-bottom: 6rem; }
.why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2.5rem; }
.why-card {
  padding: 1.5rem;
  border-radius: var(--radius);
  background: var(--surface);
  border: 1px solid var(--border);
}
.why-icon { font-size: 1.4rem; margin-bottom: 0.7rem; }
.why-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
  margin-bottom: 0.35rem;
}
.why-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.65; }

@media (max-width: 900px) {
  .products-grid { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; }
}
</style>
