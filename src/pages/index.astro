---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const products = [
  {
    name:    'Kixlogic ATS',
    tagline: 'Applicant Tracking for Life Sciences',
    desc:    'Post jobs, manage pipelines, score candidates with AI. Designed for the pace of scientific recruiting — from sourcing researchers to extending offers.',
    href:    '/ats',
    color:   '#14B894',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="2" stroke="#14B894" stroke-width="1.5"/><path d="M7 9h10M7 13h6" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/><circle cx="17" cy="16" r="3" fill="#14B894" opacity=".3"/><path d="M16 16l1 1 1.5-1.5" stroke="#14B894" stroke-width="1.2" stroke-linecap="round"/></svg>`,
    features: ['AI-scored candidates', 'Scientific sourcing', 'JD builder', 'Offer management'],
  },
  {
    name:    'Kixlogic Comp',
    tagline: 'Compensation Intelligence',
    desc:    'Market pay benchmarks, offer analysis, pay equity, and compa-ratio reporting — built for biotech, pharma, med device, and clinical research.',
    href:    '/comp',
    color:   '#6366F1',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M3 17l4-4 4 4 4-6 4 3" stroke="#6366F1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="19" cy="5" r="3" fill="#6366F1" opacity=".3"/></svg>`,
    features: ['Market benchmarks', 'Offer analyzer', 'Pay equity', 'Batch reporting'],
  },
  {
    name:    'More coming',
    tagline: 'Workforce Planning — Stage 3',
    desc:    'Merit cycles, headcount forecasting, and retention risk signals. The full workforce intelligence stack for life sciences organizations.',
    href:    '#',
    color:   '#3D6370',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#3D6370" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="#3D6370" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    features: ['Merit cycles', 'Headcount forecasting', 'Retention signals', 'Budget planning'],
    soon: true,
  },
];

const pillars = [
  {
    title: 'Life sciences by design',
    desc:  'Every feature is built for biotech, pharma, medical device, and clinical research — not retrofitted from a generic HR tool.',
    icon:  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M9 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V9l-6-6z" stroke="#14B894" stroke-width="1.5"/><path d="M9 3v6h6" stroke="#14B894" stroke-width="1.5"/><circle cx="9" cy="14" r="1.5" fill="#14B894" opacity=".5"/><circle cx="12" cy="12" r="1.5" fill="#14B894"/><circle cx="15" cy="15" r="1.5" fill="#14B894" opacity=".5"/></svg>`,
  },
  {
    title: 'AI that works for scientists',
    desc:  'Candidate scoring, JD generation, salary benchmarks, and sourcing — powered by models trained on scientific roles, not generic job titles.',
    icon:  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="3" y="8" width="18" height="11" rx="3" stroke="#14B894" stroke-width="1.5"/><path d="M8 8V6a4 4 0 0 1 8 0v2" stroke="#14B894" stroke-width="1.5"/><circle cx="12" cy="14" r="2" fill="#14B894" opacity=".5"/></svg>`,
  },
  {
    title: 'One platform, three apps',
    desc:  'ATS, Comp Intelligence, and Workforce Planning under one login. No re-keying data, no re-authenticating, no "request a quote" walls.',
    icon:  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="8" height="8" rx="2" stroke="#14B894" stroke-width="1.5"/><rect x="13" y="3" width="8" height="8" rx="2" stroke="#14B894" stroke-width="1.5" opacity=".6"/><rect x="3" y="13" width="8" height="8" rx="2" stroke="#14B894" stroke-width="1.5" opacity=".6"/><rect x="13" y="13" width="8" height="8" rx="2" stroke="#14B894" stroke-width="1.5" opacity=".3"/></svg>`,
  },
];
---
<Base
  title="Kixlogic"
  description="Workforce Intelligence Platform for life sciences. ATS, comp benchmarks, and scientific sourcing — purpose-built for biotech, pharma, and medical device organizations."
>
  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="hero section">
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="tag">Workforce Intelligence Platform</span>
      </div>
      <h1 class="hero-headline">
        The Bloomberg Terminal<br />
        <span class="accent">for scientific talent</span>
      </h1>
      <p class="hero-sub">
        Hire, pay, and retain the specialized scientists your organization needs.
        ATS, compensation intelligence, and candidate sourcing — purpose-built for life sciences.
      </p>
      <div class="hero-actions">
        <a href="https://app.kixlogic.com/dashboard" class="btn btn-primary">
          Start free trial
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <a href="/ats" class="btn btn-outline">See Kixlogic ATS</a>
      </div>
      <p class="hero-note">No credit card required · 14-day free trial</p>

      <!-- Dashboard preview mockup -->
      <div class="hero-visual" aria-hidden="true">
        <div class="mockup-bar">
          <span></span><span></span><span></span>
          <div class="mockup-url">app.kixlogic.com</div>
        </div>
        <div class="mockup-body">
          <div class="mockup-sidebar">
            <div class="ms-item active">Dashboard</div>
            <div class="ms-item">Pipeline</div>
            <div class="ms-item">Sourcing</div>
            <div class="ms-item">Comp Intel</div>
            <div class="ms-item">Jobs</div>
          </div>
          <div class="mockup-content">
            <div class="mockup-row">
              <div class="stat-card">
                <div class="stat-value" style="color:#14B894">142</div>
                <div class="stat-label">Active candidates</div>
              </div>
              <div class="stat-card">
                <div class="stat-value" style="color:#6366F1">8</div>
                <div class="stat-label">Open positions</div>
              </div>
              <div class="stat-card">
                <div class="stat-value" style="color:#14B894">24d</div>
                <div class="stat-label">Avg. time to hire</div>
              </div>
            </div>
            <div class="mockup-pipeline">
              <div class="pipe-col">
                <div class="pipe-header">Screening</div>
                <div class="pipe-card">J. Patel · Sr. Bioinformatics</div>
                <div class="pipe-card">M. Chen · Reg. Affairs</div>
              </div>
              <div class="pipe-col">
                <div class="pipe-header">Interviews</div>
                <div class="pipe-card">R. Okonkwo · CRA II</div>
              </div>
              <div class="pipe-col">
                <div class="pipe-header">Offer</div>
                <div class="pipe-card accent-card">L. Nguyen · Princ. Sci.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Products ──────────────────────────────────────────────────────── -->
  <section class="section" id="products">
    <div class="container">
      <div class="section-header">
        <span class="tag">Platform</span>
        <h2>Three apps. One login.</h2>
        <p>Kixlogic Workforce Intelligence Platform covers the full talent lifecycle — from sourcing a researcher to planning next year's merit cycle.</p>
      </div>
      <div class="products-grid">
        {products.map(p => (
          <div class={`product-card card ${p.soon ? 'soon' : ''}`}>
            <div class="product-icon" set:html={p.icon} />
            <div>
              <div class="product-name-row">
                <h3>{p.name}</h3>
                {p.soon && <span class="soon-badge">Coming soon</span>}
              </div>
              <p class="product-tagline">{p.tagline}</p>
            </div>
            <p class="product-desc">{p.desc}</p>
            <ul class="product-features">
              {p.features.map(f => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7l3 3 6-6" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            {!p.soon && (
              <a href={p.href} class="product-link">
                Learn more
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M4 7h6M8 5l2 2-2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Pillars ────────────────────────────────────────────────────────── -->
  <section class="section pillars-section">
    <div class="container">
      <div class="section-header">
        <span class="tag">Why Kixlogic</span>
        <h2>Built for the complexity<br />of scientific hiring</h2>
      </div>
      <div class="pillars-grid">
        {pillars.map(p => (
          <div class="pillar">
            <div class="pillar-icon" set:html={p.icon} />
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ────────────────────────────────────────────────────── -->
  <section class="section-sm cta-banner">
    <div class="container cta-inner">
      <div>
        <h2>Ready to hire better scientists?</h2>
        <p>Join life sciences teams that use Kixlogic WIP to source, evaluate, and hire faster.</p>
      </div>
      <div class="cta-actions">
        <a href="https://app.kixlogic.com/dashboard" class="btn btn-primary">Start free trial</a>
        <a href="/contact" class="btn btn-outline">Talk to us</a>
      </div>
    </div>
  </section>

  <!-- ── Blog Preview ──────────────────────────────────────────────────── -->
  {posts.length > 0 && (
    <section class="section" id="blog">
      <div class="container">
        <div class="section-header" style="margin-bottom:2.5rem">
          <span class="tag">Blog</span>
          <h2>From the Kixlogic team</h2>
        </div>
        <div class="blog-preview-grid">
          {posts.map(post => {
            const d = post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            return (
              <a href={`/blog/${post.slug}`} class="blog-card card">
                <div class="blog-card-tags">
                  {post.data.tags.slice(0,2).map(t => <span class="tag" style="font-size:0.7rem;padding:0.15rem 0.6rem">{t}</span>)}
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="blog-card-footer">
                  <span>{post.data.author}</span>
                  <time>{d}</time>
                </div>
              </a>
            );
          })}
        </div>
        <div style="text-align:center;margin-top:2.5rem">
          <a href="/blog" class="btn btn-outline">All posts →</a>
        </div>
      </div>
    </section>
  )}
</Base>

<style>
/* ── Hero ── */
.hero { padding-top: 6rem; padding-bottom: 2rem; }
.hero-inner { display: flex; flex-direction: column; align-items: center; text-align: center; }
.hero-badge { margin-bottom: 1.5rem; }
.hero-headline {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2.5rem, 6vw, 4.25rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin-bottom: 1.25rem;
  max-width: 800px;
}
.accent { color: var(--gold); }
.hero-sub {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--text-muted);
  max-width: 600px;
  margin-bottom: 2rem;
  line-height: 1.7;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-bottom: 0.75rem; }
.hero-note { font-size: 0.8rem; color: var(--text-dim); margin-bottom: 4rem; }

/* Dashboard mockup */
.hero-visual {
  width: 100%;
  max-width: 860px;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04);
}
.mockup-bar {
  height: 36px;
  background: var(--navy-3);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0 1rem;
}
.mockup-bar span {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
}
.mockup-url {
  margin-left: 1rem;
  font-size: 0.7rem;
  color: var(--text-dim);
  background: rgba(255,255,255,0.05);
  padding: 0.2rem 0.75rem;
  border-radius: 4px;
  flex: 1;
  max-width: 200px;
  text-align: center;
}
.mockup-body {
  display: grid;
  grid-template-columns: 160px 1fr;
}
.mockup-sidebar {
  padding: 1rem 0.75rem;
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.ms-item {
  padding: 0.5rem 0.75rem;
  border-radius: 7px;
  font-size: 0.75rem;
  color: var(--text-muted);
}
.ms-item.active {
  background: var(--gold-dim);
  color: var(--gold);
  font-weight: 600;
}
.mockup-content { padding: 1.25rem; }
.mockup-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.75rem;
}
.stat-value { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 800; }
.stat-label { font-size: 0.65rem; color: var(--text-dim); margin-top: 2px; }
.mockup-pipeline { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
.pipe-col {}
.pipe-header { font-size: 0.65rem; font-weight: 700; color: var(--text-dim); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.5rem; }
.pipe-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.5rem 0.625rem;
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-bottom: 0.4rem;
}
.accent-card { border-color: var(--border-gold); color: var(--gold); background: var(--gold-dim); }

/* ── Section header ── */
.section-header {
  text-align: center;
  margin-bottom: 3.5rem;
}
.section-header .tag { margin-bottom: 1rem; }
.section-header h2 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: 1rem;
  color: var(--text);
}
.section-header p {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.7;
}

/* ── Products ── */
.products-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.product-card { display: flex; flex-direction: column; gap: 1rem; }
.product-card.soon { opacity: 0.6; }
.product-card.soon:hover { opacity: 0.7; }
.product-icon {
  width: 56px; height: 56px;
  background: var(--surface-2);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border);
}
.product-name-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.product-name-row h3 {
  font-family: 'Syne', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text);
}
.soon-badge {
  font-size: 0.7rem;
  background: var(--surface-2);
  border: 1px solid var(--border);
  color: var(--text-dim);
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  font-weight: 600;
  letter-spacing: 0.04em;
}
.product-tagline { font-size: 0.8rem; color: var(--text-dim); margin-top: 0.15rem; }
.product-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; flex: 1; }
.product-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.product-features li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--text-muted);
}
.product-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--gold);
  margin-top: auto;
  transition: gap 0.2s;
}
.product-link:hover { gap: 0.6rem; }

/* ── Pillars ── */
.pillars-section { background: linear-gradient(180deg, transparent, rgba(20,184,148,0.03) 50%, transparent); }
.pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.pillar {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 2rem;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  background: var(--surface);
}
.pillar-icon {
  width: 52px; height: 52px;
  background: var(--surface-2);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
}
.pillar h3 {
  font-family: 'Syne', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text);
}
.pillar p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }

/* ── CTA Banner ── */
.cta-banner { background: linear-gradient(135deg, rgba(20,184,148,0.08), rgba(99,102,241,0.08)); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
.cta-inner h2 { font-family: 'Syne', sans-serif; font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; }
.cta-inner p { color: var(--text-muted); }
.cta-actions { display: flex; gap: 1rem; flex-shrink: 0; }

/* ── Blog preview ── */
.blog-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.blog-card { display: flex; flex-direction: column; gap: 0.875rem; text-decoration: none; }
.blog-card:hover h3 { color: var(--gold); }
.blog-card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.blog-card h3 { font-family: 'Syne', sans-serif; font-size: 1.05rem; font-weight: 700; color: var(--text); line-height: 1.4; transition: color 0.2s; }
.blog-card p  { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; flex: 1; }
.blog-card-footer {
  display: flex;
  justify-content: space-between;
  font-size: 0.78rem;
  color: var(--text-dim);
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}

@media (max-width: 900px) {
  .products-grid   { grid-template-columns: 1fr 1fr; }
  .pillars-grid    { grid-template-columns: 1fr 1fr; }
  .blog-preview-grid { grid-template-columns: 1fr 1fr; }
  .mockup-sidebar  { display: none; }
  .mockup-body     { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .products-grid   { grid-template-columns: 1fr; }
  .pillars-grid    { grid-template-columns: 1fr; }
  .blog-preview-grid { grid-template-columns: 1fr; }
  .cta-inner       { flex-direction: column; text-align: center; }
  .cta-actions     { justify-content: center; }
  .mockup-row      { grid-template-columns: 1fr 1fr; }
  .mockup-pipeline { grid-template-columns: 1fr; }
}
</style>
