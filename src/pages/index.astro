---
import Base from '../layouts/Base.astro';
import HomepageSections from '../components/HomepageSections.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
import homepage from '../data/homepage.json';
import type { HomepageData } from '../lib/cms-types';

const home = homepage as HomepageData;
---
<Base title={home.seo.title} description={home.seo.description}>
  <HomepageSections data={home} />
  <BlogTeaser />
</Base>
