---
import Base from '../layouts/Base.astro';
import { atsFeatures, tagLabels, steps } from '../data/ats-features';
---
<Base
  title="Kixlogic ATS"
  description="Kixlogic ATS is built for small and mid-sized businesses. AI resume scoring, advanced analytics, white-label careers pages, and more. Launch in 10 minutes from any browser."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow">✦ 100% cloud &nbsp;·&nbsp; No software to install</div>
        <h1 class="hero-title">
          Hire smarter.<br />
          <span class="line-2">Your way.</span>
        </h1>
        <p class="hero-sub">
          Kixlogic ATS is built for small and mid-sized businesses. Launch in 10 minutes from any browser — AI resume scoring, advanced analytics, white-label careers pages, and more. No software to install, no IT team required.
        </p>
        <div class="hero-actions">
          <button type="button" class="btn btn-primary btn-lg" data-checkout="growth">Start Free Trial →</button>
          <a href="#ats-features" class="btn btn-outline btn-lg">See All Features</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hero-stat-num">14-day</div>
            <div class="hero-stat-label">Free trial</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">&lt;10min</div>
            <div class="hero-stat-label">Setup time</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">AI</div>
            <div class="hero-stat-label">Resume scoring</div>
          </div>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="dashboard-mock">
          <div class="mock-bar">
            <div class="mock-dots">
              <span class="mock-dot red"></span>
              <span class="mock-dot yellow"></span>
              <span class="mock-dot green"></span>
            </div>
            <div class="mock-title">Kixlogic ATS · Applications</div>
          </div>
          <div class="mock-body">
            <div class="mock-nav">
              <div class="mock-nav-item">📊 Overview</div>
              <div class="mock-nav-item">💼 Job Postings</div>
              <div class="mock-nav-item active">👥 Applications</div>
              <div class="mock-nav-item">🗂️ Pipeline</div>
              <div class="mock-nav-item">🔍 Resume Search</div>
              <div class="mock-nav-item">📈 Reports</div>
            </div>
            <div class="mock-content">
              <div class="mock-card">
                <div class="mock-row">
                  <div class="mock-avatar"></div>
                  <div class="mock-lines">
                    <div class="mock-line w60"></div>
                    <div class="mock-line w40 gold"></div>
                  </div>
                  <span class="mock-badge green">New</span>
                </div>
                <div class="mock-score">
                  <div class="mock-score-label">AI Resume Match</div>
                  <div class="mock-score-meta">
                    <span class="mock-stars">★★★★<span class="dim">★</span></span>
                    <span class="match-pct">82% match</span>
                  </div>
                  <div class="mock-score-bar-bg"><div class="mock-score-bar"></div></div>
                </div>
              </div>
              <div class="mock-card faded">
                <div class="mock-row">
                  <div class="mock-avatar purple"></div>
                  <div class="mock-lines">
                    <div class="mock-line w55"></div>
                    <div class="mock-line w35"></div>
                  </div>
                  <span class="mock-badge blue">Review</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="ats-features">
    <div class="container">
      <span class="section-tag">✦ Full feature breakdown</span>
      <h2 class="section-title">Everything Kixlogic ATS can do</h2>
      <p class="section-sub">Four plans, one platform. Start lean and scale up as your hiring grows — from Starter through Enterprise.</p>

      <div class="features-grid">
        {atsFeatures.map(f => (
          <div class={`feature-card ${f.wide ? 'wide' : ''}`}>
            <div class="feature-icon">{f.icon}</div>
            <div class="feature-title">{f.title}</div>
            <div class="feature-desc">{f.desc}</div>
            <div class={`feature-tag tag-${f.tag}`}>{tagLabels[f.tag]}</div>
          </div>
        ))}
      </div>

      <p class="feature-footnote">
        * Search engine indexing depends on each crawler's schedule (typically 1–2 weeks for new sites). Other job boards (Indeed, LinkedIn, ZipRecruiter) require their own paid or free employer accounts.
      </p>

      <div class="teams-banner">
        <div>
          <span class="section-tag">✦ Included with Growth+</span>
          <div class="teams-title">Manager Review Workflow</div>
          <div class="teams-desc">
            Forward applicants directly to hiring managers with one click. A full application summary — name, contact info, employment history, skills, and availability — lands in their inbox instantly. Every send is automatically logged in the applicant record with a timestamp. No logins required for the manager.
          </div>
          <a href="/pricing/" class="btn btn-outline" style="margin-top:1.5rem">See Pricing →</a>
        </div>
        <div class="teams-logo">📤</div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section steps-section">
    <div class="container">
      <div class="text-center">
        <span class="section-tag">✦ Simple by design</span>
      </div>
      <h2 class="section-title text-center">Up and running in minutes</h2>
      <p class="section-sub text-center mx-auto">Sign up from any browser — you'll be posting jobs and reviewing applications in under 10 minutes.</p>
      <div class="steps">
        {steps.map(s => (
          <div class="step">
            <div class="step-num">{s.num}</div>
            <div class="step-title">{s.title}</div>
            <div class="step-desc">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="section">
    <div class="container">
      <div class="text-center">
        <span class="section-tag">✦ Product</span>
      </div>
      <h2 class="section-title text-center">See it in action</h2>
      <p class="section-sub text-center mx-auto">The dashboard your hiring team actually wants to use.</p>
      <div class="screenshots-grid">
        <figure class="screenshot-card">
          <img src="/images/dashboard.png" alt="Kixlogic ATS dashboard overview" loading="lazy" width="1200" height="675" />
          <figcaption>Dashboard overview — open roles, pipeline stats, and recent activity</figcaption>
        </figure>
        <figure class="screenshot-card">
          <img src="/images/pipeline.png" alt="Kixlogic ATS candidate pipeline" loading="lazy" width="1200" height="675" />
          <figcaption>Candidate pipeline — drag-and-drop stages with AI scores</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container text-center">
      <span class="section-tag">✦ Start today</span>
      <h2 class="section-title">Ready to hire smarter?</h2>
      <p class="section-sub mx-auto">Start your 14-day free trial today. Everything runs in the cloud — you'll be up and running in minutes.</p>
      <button type="button" class="btn btn-primary btn-lg" data-checkout="growth">Start Free Trial →</button>
      <p class="cta-note">Card required. Cancel before trial ends and pay nothing.</p>
    </div>
  </section>
</Base>

<style>
.hero {
  padding: 4rem 0;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  padding: 0.35rem 1rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.5rem;
}
.hero-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1.1;
  letter-spacing: -2px;
  margin-bottom: 1.25rem;
}
.line-2 {
  background: linear-gradient(135deg, var(--gold), var(--gold-light), #fff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  font-size: 1.1rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 2rem;
  max-width: 480px;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.btn-lg { padding: 0.95rem 2.25rem; font-size: 1rem; border-radius: 12px; }
.hero-stats { display: flex; gap: 2rem; flex-wrap: wrap; }
.hero-stat-num {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.5rem;
  color: var(--gold);
  line-height: 1;
}
.hero-stat-label { font-size: 0.78rem; color: var(--text-dim); margin-top: 2px; }

.hero-visual { position: relative; }
.hero-visual::before {
  content: '';
  position: absolute;
  inset: -40px;
  background: radial-gradient(ellipse at center, rgba(20,184,148,0.08), transparent 70%);
  pointer-events: none;
  z-index: -1;
}
.dashboard-mock {
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  animation: mockFloat 6s ease-in-out infinite;
}
@keyframes mockFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}
.mock-bar {
  background: var(--navy-3);
  padding: 0.65rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  border-bottom: 1px solid var(--border);
}
.mock-dots { display: flex; gap: 5px; }
.mock-dot { width: 10px; height: 10px; border-radius: 50%; }
.mock-dot.red { background: #ef4444; }
.mock-dot.yellow { background: #f59e0b; }
.mock-dot.green { background: #22c55e; }
.mock-title { font-size: 0.72rem; color: var(--text-dim); margin-left: 0.5rem; font-family: 'Syne', sans-serif; }
.mock-body { padding: 1rem; display: grid; grid-template-columns: 140px 1fr; gap: 0.75rem; min-height: 280px; }
.mock-nav { display: flex; flex-direction: column; gap: 0.25rem; }
.mock-nav-item {
  padding: 0.45rem 0.65rem;
  border-radius: 7px;
  font-size: 0.68rem;
  color: var(--text-dim);
}
.mock-nav-item.active { background: rgba(20,184,148,0.15); color: var(--gold); }
.mock-content { display: flex; flex-direction: column; gap: 0.6rem; }
.mock-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.75rem;
}
.mock-card.faded { opacity: 0.7; }
.mock-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.35rem; }
.mock-avatar {
  width: 24px; height: 24px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold), #2563eb);
  flex-shrink: 0;
}
.mock-avatar.purple { background: linear-gradient(135deg, #7c3aed, #2563eb); }
.mock-lines { flex: 1; }
.mock-line { height: 8px; border-radius: 4px; background: var(--surface-2); margin-bottom: 5px; }
.mock-line.w60 { width: 60%; }
.mock-line.w55 { width: 55%; }
.mock-line.w40 { width: 40%; }
.mock-line.w35 { width: 35%; }
.mock-line.gold { background: rgba(20,184,148,0.15); }
.mock-badge { font-size: 0.6rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; }
.mock-badge.green { background: rgba(34,197,94,0.15); color: #4ade80; }
.mock-badge.blue { background: rgba(37,99,235,0.15); color: #60a5fa; }
.mock-score {
  background: rgba(20,184,148,0.1);
  border: 1px solid var(--border-gold);
  border-radius: 6px;
  padding: 0.5rem;
}
.mock-score-label { font-size: 0.6rem; color: var(--text-dim); margin-bottom: 0.25rem; }
.mock-score-meta { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem; }
.mock-stars { font-size: 0.65rem; }
.mock-stars .dim { color: var(--text-dim); }
.match-pct { font-size: 0.65rem; color: var(--gold); font-weight: 700; }
.mock-score-bar-bg { height: 6px; background: var(--surface-2); border-radius: 3px; }
.mock-score-bar { height: 6px; border-radius: 3px; background: linear-gradient(90deg, var(--gold), var(--gold-light)); width: 82%; }

.section-tag {
  display: inline-flex;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.25rem;
}
.section-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: -1px;
  margin-bottom: 1rem;
}
.section-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}
.text-center { text-align: center; }
.mx-auto { margin-left: auto; margin-right: auto; }

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 1rem;
}
.feature-card {
  padding: 1.75rem;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 1px solid var(--border);
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}
.feature-card:hover {
  border-color: var(--border-gold);
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
}
.feature-card.wide {
  grid-column: span 2;
  background: linear-gradient(135deg, rgba(20,184,148,0.08), rgba(10,95,117,0.08));
  border-color: rgba(20,184,148,0.3);
}
.feature-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  margin-bottom: 1.1rem;
}
.feature-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 0.5rem;
}
.feature-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; }
.feature-tag {
  display: inline-block;
  margin-top: 0.85rem;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
}
.tag-starter { background: rgba(59,130,246,0.12); color: #60a5fa; }
.tag-growth { background: rgba(20,184,148,0.12); color: #14B894; }
.tag-professional { background: rgba(139,92,246,0.12); color: #a78bfa; }
.feature-footnote {
  font-size: 0.75rem;
  color: var(--text-dim);
  margin: 0.75rem 0 2rem;
}

.teams-banner {
  background: linear-gradient(135deg, rgba(37,99,235,0.1), rgba(20,184,148,0.05));
  border: 1px solid rgba(37,99,235,0.2);
  border-radius: var(--radius-lg);
  padding: 3rem;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 2rem;
  align-items: center;
}
.teams-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}
.teams-desc { font-size: 0.925rem; color: var(--text-muted); line-height: 1.65; max-width: 520px; }
.teams-logo {
  width: 80px; height: 80px;
  border-radius: 16px;
  background: rgba(37,99,235,0.2);
  border: 1px solid rgba(37,99,235,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
}

.steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; position: relative; margin-top: 3rem; }
.steps::before {
  content: '';
  position: absolute;
  top: 32px; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-gold), transparent);
}
.step { text-align: center; padding: 0 0.5rem; }
.step-num {
  width: 64px; height: 64px;
  border-radius: 50%;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.25rem;
  color: var(--gold);
  margin: 0 auto 1rem;
  position: relative;
  z-index: 1;
}
.step-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.95rem; margin-bottom: 0.4rem; }
.step-desc { font-size: 0.825rem; color: var(--text-muted); line-height: 1.6; }

.screenshots-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.screenshot-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.screenshot-card img { width: 100%; height: auto; display: block; border-bottom: 1px solid var(--border); }
.screenshot-card figcaption { padding: 1rem 1.25rem; font-size: 0.85rem; color: var(--text-muted); }

.cta-section { padding-bottom: 6rem; }
.cta-note { margin-top: 1rem; font-size: 0.8rem; color: var(--text-dim); }

@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  .hero-visual { display: none; }
  .features-grid { grid-template-columns: 1fr 1fr; }
  .feature-card.wide { grid-column: span 2; }
  .steps { grid-template-columns: 1fr 1fr; }
  .steps::before { display: none; }
  .teams-banner { grid-template-columns: 1fr; }
  .teams-logo { display: none; }
  .screenshots-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .features-grid { grid-template-columns: 1fr; }
  .feature-card.wide { grid-column: auto; }
  .steps { grid-template-columns: 1fr; }
}
</style>
