---
import Base from '../layouts/Base.astro';

const features = [
  {
    title:   'AI-powered candidate scoring',
    desc:    'Every applicant is automatically scored against your job description. Drag-and-drop pipeline. Bulk actions. Review 50 candidates in the time it used to take to review 10.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="#14B894" stroke-width="1.5"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/><path d="M16 11l1.5 1.5L20 10" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title:   'Scientific candidate sourcing',
    desc:    'Search academic databases, research networks, and the open web for passive candidates — scientists who aren\'t on LinkedIn but whose work fits your role.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#14B894" stroke-width="1.5"/><path d="M16.5 16.5l4 4" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/><path d="M8 11h6M11 8v6" stroke="#14B894" stroke-width="1.2" stroke-linecap="round"/></svg>`,
  },
  {
    title:   'AI job description builder',
    desc:    'Generate life-sciences-specific JDs in seconds. Biotech, pharma, med device, and clinical research templates. Includes required skills, salary range, and equity guidance.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-5z" stroke="#14B894" stroke-width="1.5"/><path d="M14 3v5h5M9 13h6M9 17h4" stroke="#14B894" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  },
  {
    title:   'Team collaboration',
    desc:    'Multi-user hiring teams with role-based access. Structured scorecards, interview guides, and @mention comments. Everyone sees the same candidate, in real time.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="7" r="3" stroke="#14B894" stroke-width="1.5"/><circle cx="16" cy="9" r="2.5" stroke="#14B894" stroke-width="1.5"/><path d="M2 19c0-3.3 3.1-6 7-6" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/><path d="M13 19c0-2.8 2.2-5 5-5s5 2.2 5 5" stroke="#14B894" stroke-width="1.3" stroke-linecap="round" opacity=".7"/></svg>`,
  },
  {
    title:   'Offer & onboarding flow',
    desc:    'Generate, send, and track offer letters from the same platform. E-signature built in. Candidate completes onboarding forms before day one.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="#14B894" stroke-width="1.5"/><path d="M3 9h18" stroke="#14B894" stroke-width="1.5"/><path d="M9 14h6" stroke="#14B894" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  },
  {
    title:   'ScientificGigs job board syndication',
    desc:    'WIP tenant jobs automatically post to ScientificGigs.com — a dedicated life-sciences job board. Zero extra work. Broader reach for your open roles.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#14B894" stroke-width="1.5"/><path d="M12 3a9 9 0 0 1 6 15.7" stroke="#14B894" stroke-width="1.3" stroke-linecap="round" opacity=".5"/><path d="M3 10h18M3 14h18" stroke="#14B894" stroke-width="1.2" stroke-linecap="round" opacity=".4"/><path d="M12 3c-2.5 2.5-4 5.6-4 9s1.5 6.5 4 9" stroke="#14B894" stroke-width="1.3"/></svg>`,
  },
];

const stages = ['Post job', 'Source & apply', 'Screen & score', 'Interview', 'Offer', 'Onboard'];
---
<Base
  title="Kixlogic ATS"
  description="Applicant tracking system purpose-built for life sciences. AI candidate scoring, scientific sourcing, JD builder, team collaboration, and offer management."
>
  <!-- ── Hero ── -->
  <section class="product-hero section">
    <div class="container product-hero-inner">
      <div class="product-hero-content">
        <a href="/" class="breadcrumb">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8 3L4 7l4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Kixlogic
        </a>
        <div class="hero-badge" style="margin:1rem 0">
          <span class="tag">Kixlogic ATS</span>
        </div>
        <h1>The ATS built for<br /><span class="accent">scientific talent</span></h1>
        <p>
          Most ATS platforms were designed for volume — retail, logistics, call centers.
          Kixlogic ATS was designed for specificity: finding, evaluating, and hiring the specialized
          scientists that life sciences organizations depend on.
        </p>
        <div class="hero-actions">
          <a href="https://app.kixlogic.com/dashboard" class="btn btn-primary">Start free trial</a>
          <a href="/pricing" class="btn btn-outline">See pricing</a>
        </div>
        <p style="font-size:0.8rem;color:var(--text-dim);margin-top:0.5rem">14-day free trial · No credit card</p>
      </div>
      <div class="product-hero-visual" aria-hidden="true">
        <div class="pipeline-preview">
          <div class="pp-header">
            <span>Candidate Pipeline</span>
            <span style="color:var(--gold);font-size:0.75rem;font-weight:600">8 open roles</span>
          </div>
          {stages.map((s, i) => (
            <div class={`pp-stage ${i === 3 ? 'active' : ''}`}>
              <span class="pp-dot"></span>
              <span class="pp-label">{s}</span>
              {i < stages.length - 1 && <div class="pp-line"></div>}
            </div>
          ))}
          <div style="margin-top:1.5rem;display:flex;flex-direction:column;gap:0.5rem">
            <div class="candidate-row highlighted">
              <div class="c-avatar">JP</div>
              <div>
                <div class="c-name">J. Patel</div>
                <div class="c-role">Sr. Bioinformatics Scientist</div>
              </div>
              <div class="c-score teal">94</div>
            </div>
            <div class="candidate-row">
              <div class="c-avatar">MC</div>
              <div>
                <div class="c-name">M. Chen</div>
                <div class="c-role">Regulatory Affairs Dir.</div>
              </div>
              <div class="c-score indigo">88</div>
            </div>
            <div class="candidate-row">
              <div class="c-avatar">RO</div>
              <div>
                <div class="c-name">R. Okonkwo</div>
                <div class="c-role">Clinical Research Assoc. II</div>
              </div>
              <div class="c-score teal">82</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="tag">Features</span>
        <h2>Everything your hiring team needs</h2>
        <p>One platform for the entire scientific recruiting workflow — from job post to first day.</p>
      </div>
      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card card">
            <div class="feature-icon" set:html={f.icon} />
            <div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Screenshots ── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="tag">Product</span>
        <h2>See it in action</h2>
        <p>The dashboard your hiring team actually wants to use.</p>
      </div>
      <div class="screenshots-grid">
        <figure class="screenshot-card card">
          <img src="/images/dashboard.png" alt="Kixlogic ATS dashboard overview" loading="lazy" width="1200" height="675" />
          <figcaption>Dashboard overview — open roles, pipeline stats, and recent activity</figcaption>
        </figure>
        <figure class="screenshot-card card">
          <img src="/images/pipeline.png" alt="Kixlogic ATS candidate pipeline" loading="lazy" width="1200" height="675" />
          <figcaption>Candidate pipeline — drag-and-drop stages with AI scores</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="section-sm cta-banner">
    <div class="container cta-inner">
      <div>
        <h2>Start hiring better scientists today</h2>
        <p>Join life sciences teams using Kixlogic ATS to cut time-to-hire and improve offer acceptance.</p>
      </div>
      <div class="cta-actions">
        <a href="https://app.kixlogic.com/dashboard" class="btn btn-primary">Start free trial</a>
        <a href="/pricing" class="btn btn-outline">View pricing</a>
      </div>
    </div>
  </section>
</Base>

<style>
.product-hero { padding-top: 5rem; }
.product-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.breadcrumb {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.85rem;
  color: var(--text-muted);
  transition: color 0.2s;
}
.breadcrumb:hover { color: var(--gold); }
.product-hero-content h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2rem, 4vw, 3.25rem);
  font-weight: 800;
  letter-spacing: -0.025em;
  line-height: 1.15;
  margin-bottom: 1.25rem;
}
.accent { color: var(--gold); }
.product-hero-content p {
  color: var(--text-muted);
  font-size: 1.05rem;
  line-height: 1.7;
  margin-bottom: 2rem;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

/* Pipeline visual */
.product-hero-visual {}
.pipeline-preview {
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
}
.pp-header {
  display: flex;
  justify-content: space-between;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
  padding-bottom: 0.875rem;
  border-bottom: 1px solid var(--border);
}
.pp-stage {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.375rem 0;
}
.pp-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--surface-2);
  border: 2px solid var(--border);
  flex-shrink: 0;
  z-index: 1;
}
.pp-stage.active .pp-dot {
  background: var(--gold);
  border-color: var(--gold);
  box-shadow: 0 0 0 4px var(--gold-dim);
}
.pp-label { font-size: 0.875rem; color: var(--text-muted); }
.pp-stage.active .pp-label { color: var(--text); font-weight: 600; }
.pp-line {
  position: absolute;
  left: 4.5px;
  top: 100%;
  width: 1px;
  height: 100%;
  background: var(--border);
}

.candidate-row {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 0.625rem 0.875rem;
  border-radius: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
}
.candidate-row.highlighted {
  border-color: var(--border-gold);
  background: var(--gold-dim);
}
.c-avatar {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--text-muted);
  flex-shrink: 0;
}
.c-name { font-size: 0.8rem; font-weight: 600; color: var(--text); }
.c-role { font-size: 0.7rem; color: var(--text-muted); }
.c-score {
  margin-left: auto;
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
}
.c-score.teal   { color: var(--gold); }
.c-score.indigo { color: var(--indigo-light); }

/* Features */
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.feature-card {
  display: flex;
  gap: 1rem;
}
.feature-icon {
  width: 44px; height: 44px;
  background: var(--surface-2);
  border-radius: 11px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.feature-card h3 {
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.5rem;
}
.feature-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; }

/* CTA */
.cta-banner { background: linear-gradient(135deg, rgba(20,184,148,0.08), rgba(99,102,241,0.08)); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
.cta-inner h2 { font-family: 'Syne', sans-serif; font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; }
.cta-inner p { color: var(--text-muted); }
.cta-actions { display: flex; gap: 1rem; flex-shrink: 0; }
.section-header { text-align: center; margin-bottom: 3.5rem; }
.section-header .tag { margin-bottom: 1rem; }
.section-header h2 { font-family: 'Syne', sans-serif; font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 800; letter-spacing: -0.025em; margin-bottom: 1rem; }
.section-header p  { font-size: 1.05rem; color: var(--text-muted); max-width: 520px; margin: 0 auto; }

.screenshots-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.screenshot-card { padding: 0; overflow: hidden; }
.screenshot-card img {
  width: 100%;
  height: auto;
  display: block;
  border-bottom: 1px solid var(--border);
}
.screenshot-card figcaption {
  padding: 1rem 1.25rem;
  font-size: 0.85rem;
  color: var(--text-muted);
}

@media (max-width: 900px) {
  .product-hero-inner { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: repeat(2, 1fr); }
  .screenshots-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .features-grid { grid-template-columns: 1fr; }
  .feature-card { flex-direction: column; }
  .cta-inner { flex-direction: column; text-align: center; }
  .cta-actions { justify-content: center; }
}
</style>
