---
import Base from '../layouts/Base.astro';
import ProductToggle from '../components/ProductToggle.astro';

const featureGroups = [
  {
    label: 'Platform tools — included on every plan',
    sub: 'Merit cycles, deal tracking, earnings, and commission tools come with every account.',
    tagClass: 'tag-platform',
    tagLabel: 'Platform · Included',
    items: [
      { icon: '📋', title: 'Merit Cycles', desc: 'Annual increase management — employee import, pool budgeting, manager worksheets, approval chains, compa-ratio vs market, AI pay letters, and spend reports.' },
      { icon: '📝', title: 'Deals & Policies', desc: 'Log real estate closings and insurance policies as your source of truth for commission math.' },
      { icon: '💰', title: 'Earnings Ledger', desc: 'Per-deal gross → split → fees → net breakdown so agents see exactly what they earned.' },
      { icon: '⚡', title: 'Commission Tools', desc: 'Rules engine, income forecast, plan simulator, broker dashboard, renewals, audit, comp advisor, and more.' },
      { icon: '🤝', title: 'Built to Pair With Kixlogic ATS', desc: 'Compensation intelligence inside the hiring workflow — benchmark the role when you post it, score the package when you make the offer.' },
    ],
  },
  {
    label: 'General model — hiring & comp tools',
    sub: 'All-purpose compensation intelligence for any role, any industry — blended market ranges, offer scoring, job descriptions, pay equity, and strategy reports.',
    tagClass: 'tag-general',
    tagLabel: 'General',
    items: [
      { icon: '📊', title: 'Salary Benchmark', desc: 'Blended market ranges from job postings, company career sites, and BLS OEWS — observed, likely, and competitive bands.' },
      { icon: '⚖️', title: 'Offer Analyzer', desc: 'Score your draft offer and get a suggested winning package — base, bonus, and sign-on to land top candidates.' },
      { icon: '✍️', title: 'Job Description Builder', desc: 'AI job postings grounded in your market analysis — standard version or with comp language.' },
      { icon: '🔄', title: 'JD Refinement', desc: 'Iterate on any generated posting with natural-language instructions.' },
      { icon: '✨', title: 'Skill Premiums & Negotiation', desc: 'Skill value breakdown and counter-offer guidance so you know what each qualification is worth.' },
      { icon: '⚖️', title: 'Internal Pay Equity Analysis', desc: 'Compare internal pay gaps across roles and levels using your merit cycle employee data.' },
      { icon: '📉', title: 'Pay Compression Analysis', desc: 'Detect tenure inversions and grade/title spreads that create retention and equity risk.' },
      { icon: '📑', title: 'Compensation Strategy Report', desc: 'Executive summary of market position, hiring plan, and budget implications.' },
    ],
  },
  {
    label: 'Healthcare model',
    sub: 'Built for hospitals, clinics, and health systems where credentials and shifts drive pay.',
    tagClass: 'tag-healthcare',
    tagLabel: 'Healthcare',
    items: [
      { icon: '🏥', title: 'Clinical Comp Benchmarks', desc: 'Role ladders and license premiums tuned for acute, outpatient, and long-term care settings.' },
      { icon: '🌙', title: 'Shift Differential Modeling', desc: 'Night, weekend, and call pay impact on total clinical compensation.' },
      { icon: '💊', title: 'Sign-On & Relocation Benchmarks', desc: 'Sign-on bonus, relocation, and retention clawback norms by clinical setting.' },
    ],
  },
  {
    label: 'Insurance model',
    sub: 'Calibrated for carriers, agencies, and MGAs where commission structures dominate.',
    tagClass: 'tag-insurance',
    tagLabel: 'Insurance',
    items: [
      { icon: '📚', title: 'Book-of-Business Valuation', desc: 'Value an insurance book from policies, renewals, and commission trail.' },
      { icon: '🔄', title: 'Renewal & Residual Tracking', desc: 'Track recurring renewal income, decay, and chargebacks.' },
      { icon: '📊', title: 'Split Benchmarking', desc: 'Compare producer splits against network benchmark data.' },
      { icon: '🧾', title: '1099 Tax Intelligence', desc: 'Self-employment tax estimates, quarterly schedule, and deduction guide.' },
      { icon: '🛡️', title: 'Producer Comp Optimizer', desc: 'AI modeling for new-business vs renewal splits and overrides.' },
    ],
  },
  {
    label: 'Sales model',
    sub: 'Tuned for quota-carrying roles where OTE, accelerators, and territory define the deal.',
    tagClass: 'tag-sales',
    tagLabel: 'Sales',
    items: [
      { icon: '📈', title: 'OTE & Quota Modeling', desc: 'Base/variable splits, accelerators, and attainment tier analysis.' },
      { icon: '🎯', title: 'Sales Comp Optimization', desc: 'Compare plan designs and model quota attainment scenarios.' },
      { icon: '⚡', title: 'SPIF & Accelerator Modeling', desc: 'Model short-term incentives and accelerator tiers on total earnings.' },
    ],
  },
  {
    label: 'Real Estate model',
    sub: 'Designed for brokerages and teams where splits, caps, and GCI — not salary — matter.',
    tagClass: 'tag-realestate',
    tagLabel: 'Real Estate',
    items: [
      { icon: '🏠', title: 'Split & Cap Modeling', desc: 'Agent splits, desk fees, team overrides, and cap structures on every deal.' },
      { icon: '📊', title: 'Split Benchmarking', desc: 'Compare your brokerage split against network benchmark data.' },
      { icon: '📈', title: 'GCI Income Forecast', desc: 'Pipeline closings and renewals projected to next month and year.' },
      { icon: '🏠', title: 'GCI & Split Benchmark', desc: 'Model agent GCI, net after split and desk fees, and cap impact.' },
      { icon: '🧮', title: 'Plan Simulator', desc: 'Compare 70/30 vs 90/10 plans side-by-side before you change comp.' },
      { icon: '🔍', title: 'Commission Audit', desc: 'AI reconciles broker statements against your rules — flags underpayments.' },
    ],
  },
  {
    label: 'Restaurants model',
    sub: 'Built for operators juggling tip credit, FOH/BOH splits, and razor-thin margins.',
    tagClass: 'tag-restaurants',
    tagLabel: 'Restaurants',
    items: [
      { icon: '🍽️', title: 'Tip Pool, Shift & Seasonal Simulator', desc: 'State tip-credit presets, pool math, shift premiums, and seasonal staffing — not just AI estimates.' },
      { icon: '🏪', title: 'Multi-Unit GM & Hourly Ladder', desc: 'GM bands and FOH/BOH hourly ladders scaled by unit count and concept type.' },
      { icon: '👨‍🍳', title: 'FOH/BOH Benchmarks', desc: 'Role ladders by concept type — fast casual, fine dining, QSR.' },
    ],
  },
];
---
<Base
  title="Kixlogic CMP"
  description="Kixlogic CMP — compensation intelligence from market rates to payday. Market benchmarks, merit cycles, pay equity, and commission tracking for teams under 500."
>
  <ProductToggle active="cmp" />

  <section class="cmp-hero">
    <div class="container cmp-hero-inner">
      <div class="cmp-hero-copy">
        <span class="cmp-eyebrow">Kixlogic CMP</span>
        <h1>
          Compensation intelligence from market rates to <span class="cmp-accent">payday.</span>
        </h1>
        <p>
          Market benchmarks, merit cycles, pay equity, and commission tracking — one platform for hiring, budgeting, and showing every dollar earned.
        </p>
        <div class="cmp-hero-actions">
          <a href="https://cmp.kixlogic.com/" class="btn btn-cmp-primary">Get started free →</a>
          <a href="https://cmp.kixlogic.com/" class="btn btn-cmp-outline">Sign in</a>
        </div>
      </div>
      <div class="cmp-analyze-card">
        <h2>Analyze a role</h2>
        <p class="cmp-field-label">Compensation model</p>
        <div class="cmp-models">
          <span class="cmp-model active">🌐 General</span>
          <span class="cmp-model">📋 Healthcare</span>
          <span class="cmp-model">🔵 Insurance</span>
          <span class="cmp-model">💼 Sales</span>
          <span class="cmp-model">🏠 Real Estate</span>
          <span class="cmp-model">🍽️ Restaurants</span>
        </div>
        <label class="cmp-field-label">Job title</label>
        <div class="cmp-input">e.g. Marketing Manager, Software Engineer</div>
        <div class="cmp-row">
          <div>
            <label class="cmp-field-label">City</label>
            <div class="cmp-input">e.g. Chicago</div>
          </div>
          <div>
            <label class="cmp-field-label">State</label>
            <div class="cmp-input">Select state</div>
          </div>
        </div>
        <div class="cmp-row">
          <div>
            <label class="cmp-field-label">Experience</label>
            <div class="cmp-input filled">3–5 years</div>
          </div>
          <div>
            <label class="cmp-field-label">Company size</label>
            <div class="cmp-input filled">11–50 employees</div>
          </div>
        </div>
        <button class="cmp-cta-mock" id="cmpTryOpen">Try it free →</button>
      </div>
    </div>
  </section>

  <section class="section" id="cmp-features">
    <div class="container">
      <span class="feat-section-tag">✦ Full feature breakdown</span>
      <h2 class="feat-section-title">Everything Kixlogic CMP can do</h2>
      <p class="feat-section-sub">One general model, five industry specialists — plus platform tools like merit cycles, earnings, and commission tracking included on every plan.</p>

      {featureGroups.map(group => (
        <div class="feat-group">
          <div class="feat-group-label">{group.label}</div>
          <p class="feat-group-sub">{group.sub}</p>
          <div class="features-grid">
            {group.items.map(f => (
              <div class="feature-card">
                <div class="feature-icon">{f.icon}</div>
                <div class="feature-title">{f.title}</div>
                <div class="feature-desc">{f.desc}</div>
                <div class={`feature-tag ${group.tagClass}`}>{group.tagLabel}</div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section section-grey">
    <div class="container cmp-cta-band">
      <div>
        <span class="section-tag">Coming soon</span>
        <h2>Kixlogic CMP launches inside the Workforce Intelligence Platform</h2>
        <p>Pair compensation intelligence with Kixlogic ATS so hiring and pay decisions stay in one workflow.</p>
      </div>
      <div class="cmp-cta-buttons">
        <a href="/ats/" class="btn btn-primary">Explore Kixlogic ATS</a>
        <a href="/contact/" class="btn btn-outline">Talk to us</a>
      </div>
    </div>
  </section>

  <!-- Try-it-free analysis modal -->
  <div class="cmp-modal-overlay" id="cmpModal" hidden>
    <div class="cmp-modal" role="dialog" aria-modal="true" aria-labelledby="cmpModalTitle">
      <button class="cmp-modal-close" id="cmpModalClose" aria-label="Close">×</button>

      <!-- Form view -->
      <div id="cmpFormView">
        <h2 id="cmpModalTitle">Analyze a role</h2>
        <p class="cmpm-sub">Free sample analysis · No account required · View-only</p>

        <p class="cmpm-label">Compensation model</p>
        <div class="cmpm-models" id="cmpmModels">
          <button type="button" class="cmpm-model active" data-model="general">🌐 General</button>
          <button type="button" class="cmpm-model" data-model="healthcare">🏥 Healthcare</button>
          <button type="button" class="cmpm-model" data-model="insurance">🛡️ Insurance</button>
          <button type="button" class="cmpm-model" data-model="sales">📈 Sales</button>
          <button type="button" class="cmpm-model" data-model="realestate">🏠 Real Estate</button>
          <button type="button" class="cmpm-model" data-model="restaurants">🍽️ Restaurants</button>
        </div>

        <label class="cmpm-label" for="cmpmTitle">Job title</label>
        <input class="cmpm-input" id="cmpmTitle" type="text" placeholder="e.g. Marketing Manager, Software Engineer, HR Generalist" />

        <div class="cmpm-row">
          <div>
            <label class="cmpm-label" for="cmpmCity">City</label>
            <input class="cmpm-input" id="cmpmCity" type="text" placeholder="e.g. Chicago" />
          </div>
          <div>
            <label class="cmpm-label" for="cmpmState">State</label>
            <select class="cmpm-input" id="cmpmState">
              <option value="">Select state</option>
            </select>
          </div>
        </div>

        <div class="cmpm-row">
          <div>
            <label class="cmpm-label" for="cmpmExp">Experience required</label>
            <select class="cmpm-input" id="cmpmExp">
              <option value="0-2">0–2 years</option>
              <option value="3-5" selected>3–5 years</option>
              <option value="5-8">5–8 years</option>
              <option value="8-12">8–12 years</option>
              <option value="12+">12+ years</option>
            </select>
          </div>
          <div>
            <label class="cmpm-label" for="cmpmSize">Company size</label>
            <select class="cmpm-input" id="cmpmSize">
              <option value="1-10">1–10 employees</option>
              <option value="11-50" selected>11–50 employees</option>
              <option value="51-200">51–200 employees</option>
              <option value="201-500">201–500 employees</option>
              <option value="500+">500+ employees</option>
            </select>
          </div>
        </div>

        <label class="cmpm-label" for="cmpmIndustry">Industry <span class="cmpm-optional">(optional)</span></label>
        <input class="cmpm-input" id="cmpmIndustry" type="text" placeholder="e.g. Healthcare, Technology, Manufacturing, Retail" />

        <p class="cmpm-error" id="cmpmError" hidden>Please enter a job title and select a state.</p>
        <button class="cmpm-run" id="cmpmRun">Run free analysis →</button>
      </div>

      <!-- Loading view -->
      <div id="cmpLoadingView" hidden>
        <div class="cmpm-spinner"></div>
        <p class="cmpm-loading-text">Analyzing market data…</p>
      </div>

      <!-- Results view (view-only) -->
      <div id="cmpResultsView" hidden>
        <p class="cmpm-results-eyebrow">Sample compensation analysis</p>
        <h2 class="cmpm-results-title" id="cmprRole"></h2>
        <p class="cmpm-results-meta" id="cmprMeta"></p>

        <div class="cmpm-bands" id="cmprBands"></div>

        <div class="cmpm-insights">
          <p class="cmpm-insights-title">Market insights</p>
          <ul id="cmprInsights"></ul>
        </div>

        <div class="cmpm-signup">
          <p>This is a view-only sample. Sign up for full AI analyses with live market data, offer scoring, and downloadable reports.</p>
          <a href="/contact/" class="cmpm-signup-pill">Sign up now →</a>
        </div>

        <button class="cmpm-again" id="cmpmAgain">← Run another analysis</button>
      </div>
    </div>
  </div>
</Base>

<style>
.cmp-hero {
  background: linear-gradient(160deg, #0b1f3f 0%, #102a54 55%, #0d2244 100%);
  color: #fff;
  padding: 3.5rem 0 4rem;
}
.cmp-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2.5rem;
  align-items: center;
}
.cmp-eyebrow {
  display: inline-block;
  font-size: 1.2rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #7ee0b8;
  margin-bottom: 1rem;
}
.cmp-hero-copy h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 600;
  line-height: 1.15;
  margin-bottom: 1rem;
}
.cmp-accent { color: #1db980; }
.cmp-hero-copy p {
  font-size: 1rem;
  line-height: 1.65;
  color: rgba(255,255,255,0.82);
  max-width: 520px;
  margin-bottom: 1.5rem;
}
.cmp-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.btn-cmp-primary {
  background: #1db980;
  color: #fff;
  border: none;
  padding: 0.7rem 1.25rem;
  border-radius: var(--radius);
  font-weight: 600;
  font-size: 0.9375rem;
}
.btn-cmp-primary:hover { background: #17a06d; }
.btn-cmp-outline {
  border: 1px solid rgba(255,255,255,0.35);
  color: #fff;
  padding: 0.7rem 1.25rem;
  border-radius: var(--radius);
  font-weight: 600;
  font-size: 0.9375rem;
}
.btn-cmp-outline:hover { border-color: #fff; }

.cmp-analyze-card {
  background: #fff;
  color: var(--text);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  box-shadow: 0 20px 50px rgba(0,0,0,0.25);
}
.cmp-analyze-card h2 {
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 1rem;
}
.cmp-field-label {
  display: block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.35rem;
}
.cmp-models { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
.cmp-model {
  padding: 0.35rem 0.85rem;
  border-radius: var(--radius-pill);
  background: #f3f4f6;
  color: var(--text-muted);
  font-size: 0.75rem;
  font-weight: 600;
}
.cmp-model.active { background: #d7f5e8; color: #0f6b4d; }
.cmp-input {
  border: 1px solid var(--border);
  background: #f9fafb;
  border-radius: 8px;
  padding: 0.65rem 0.75rem;
  font-size: 0.8125rem;
  color: #9ca3af;
  margin-bottom: 0.85rem;
}
.cmp-input.filled { color: var(--text); }
.cmp-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}
.cmp-cta-mock {
  margin-top: 0.5rem;
  background: #1db980;
  color: #fff;
  text-align: center;
  font-weight: 600;
  padding: 0.8rem;
  border-radius: 10px;
}

.feat-section-tag {
  display: inline-flex;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 1.25rem;
}
.feat-section-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: -1px;
  margin-bottom: 1rem;
}
.feat-section-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 1rem;
}
.feature-card {
  padding: 1.75rem;
  border-radius: var(--radius-lg);
  background: var(--surface);
  border: 1px solid var(--border);
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}
.feature-card:hover {
  border-color: var(--border-gold);
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
}
.feature-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: var(--gold-dim);
  border: 1px solid var(--border-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  margin-bottom: 1.1rem;
}
.feature-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 0.5rem;
}
.feature-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; }
.feature-tag {
  display: inline-block;
  margin-top: 0.85rem;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
}
.tag-platform    { background: rgba(10,95,117,0.12);  color: #0A5F75; }
.tag-general     { background: rgba(20,184,148,0.12); color: #14B894; }
.tag-healthcare  { background: rgba(239,68,68,0.12);  color: #dc2626; }
.tag-insurance   { background: rgba(59,130,246,0.12); color: #3b82f6; }
.tag-sales       { background: rgba(139,92,246,0.12); color: #8b5cf6; }
.tag-realestate  { background: rgba(202,80,16,0.12);  color: #ca5010; }
.tag-restaurants { background: rgba(236,72,153,0.12); color: #db2777; }

.feat-group { margin-bottom: 2.5rem; }
.feat-group-label {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ms-blue);
  margin-bottom: 0.35rem;
}
.feat-group-sub {
  font-size: 0.9375rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
  max-width: 640px;
}

.cmp-cta-band {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}
.section-tag {
  display: inline-flex;
  padding: 0.3rem 0.85rem;
  border-radius: 99px;
  background: #fff4ce;
  border: 1px solid #fde7a0;
  font-size: 0.75rem;
  font-weight: 700;
  color: #ca5010;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 0.75rem;
}
.cmp-cta-band h2 {
  font-size: clamp(1.35rem, 3vw, 1.75rem);
  font-weight: 600;
  margin-bottom: 0.5rem;
}
.cmp-cta-band p { color: var(--text-muted); max-width: 520px; }
.cmp-cta-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; }

@media (max-width: 900px) {
  .cmp-hero-inner { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .features-grid { grid-template-columns: 1fr; }
}

/* ── Try-it-free modal ─────────────────────────────────────────── */
.cmp-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(11, 31, 63, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
}
.cmp-modal-overlay[hidden] { display: none; }
.cmp-modal {
  position: relative;
  background: #fff;
  color: var(--text);
  border-radius: 14px;
  max-width: 640px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  padding: 2rem 2rem 1.75rem;
  box-shadow: 0 24px 80px rgba(0,0,0,0.35);
}
.cmp-modal-close {
  position: absolute;
  top: 0.75rem;
  right: 0.9rem;
  background: none;
  border: none;
  font-size: 1.75rem;
  line-height: 1;
  color: var(--text-muted);
  cursor: pointer;
  padding: 0.25rem;
}
.cmp-modal-close:hover { color: var(--text); }
.cmp-modal h2 { font-size: 1.35rem; font-weight: 700; margin-bottom: 0.25rem; }
.cmpm-sub { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1.25rem; }
.cmpm-label {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0.9rem 0 0.35rem;
}
.cmpm-optional { font-weight: 400; text-transform: none; letter-spacing: 0; }
.cmpm-models { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.cmpm-model {
  padding: 0.4rem 0.85rem;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: #f7f8f9;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text);
  cursor: pointer;
  transition: all var(--transition);
}
.cmpm-model:hover { border-color: #1db980; }
.cmpm-model.active {
  background: #e5f8f0;
  border-color: #1db980;
  color: #0d7a54;
}
.cmpm-input {
  width: 100%;
  padding: 0.6rem 0.8rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 0.9rem;
  font-family: inherit;
  color: var(--text);
  background: #fff;
}
.cmpm-input:focus { outline: 2px solid #1db980; outline-offset: -1px; }
.cmpm-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
.cmpm-error { color: #dc2626; font-size: 0.82rem; margin-top: 0.75rem; }
.cmpm-run {
  width: 100%;
  margin-top: 1.25rem;
  padding: 0.8rem;
  border: none;
  border-radius: 8px;
  background: #1db980;
  color: #fff;
  font-size: 0.95rem;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  transition: background var(--transition);
}
.cmpm-run:hover { background: #169a6a; }

#cmpLoadingView { text-align: center; padding: 3rem 0; }
.cmpm-spinner {
  width: 42px;
  height: 42px;
  margin: 0 auto 1rem;
  border: 4px solid #e5f8f0;
  border-top-color: #1db980;
  border-radius: 50%;
  animation: cmpmSpin 0.8s linear infinite;
}
@keyframes cmpmSpin { to { transform: rotate(360deg); } }
.cmpm-loading-text { color: var(--text-muted); font-size: 0.9rem; }

/* Results — view-only */
#cmpResultsView { user-select: none; -webkit-user-select: none; }
.cmpm-results-eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #0d7a54;
  margin-bottom: 0.35rem;
}
.cmpm-results-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.2rem; }
.cmpm-results-meta { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.4rem; }
.cmpm-bands { display: flex; flex-direction: column; gap: 0.9rem; margin-bottom: 1.5rem; }
.cmpm-band {
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.9rem 1.1rem;
}
.cmpm-band.likely { border-color: #1db980; background: #f2fbf7; }
.cmpm-band-name { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.25rem; }
.cmpm-band.likely .cmpm-band-name { color: #0d7a54; }
.cmpm-band-range { font-size: 1.25rem; font-weight: 800; letter-spacing: -0.5px; }
.cmpm-band-hourly { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.15rem; }
.cmpm-insights { margin-bottom: 1.5rem; }
.cmpm-insights-title { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.5rem; }
.cmpm-insights ul { list-style: none; display: flex; flex-direction: column; gap: 0.45rem; }
.cmpm-insights li { font-size: 0.875rem; color: var(--text-muted); line-height: 1.5; padding-left: 1.1rem; position: relative; }
.cmpm-insights li::before { content: '✦'; position: absolute; left: 0; color: #1db980; font-size: 0.7rem; top: 0.2rem; }
.cmpm-signup {
  background: linear-gradient(135deg, #0b1f3f, #102a54);
  color: #fff;
  border-radius: 10px;
  padding: 1.25rem 1.4rem;
  margin-bottom: 1rem;
}
.cmpm-signup p { font-size: 0.85rem; line-height: 1.55; color: rgba(255,255,255,0.85); margin-bottom: 0.85rem; }
.cmpm-signup-pill {
  display: inline-block;
  background: #1db980;
  color: #fff;
  font-weight: 700;
  font-size: 0.9rem;
  padding: 0.6rem 1.4rem;
  border-radius: 999px;
  transition: background var(--transition);
}
.cmpm-signup-pill:hover { background: #169a6a; }
.cmpm-again {
  background: none;
  border: none;
  color: var(--ms-blue);
  font-size: 0.85rem;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  padding: 0;
}
.cmpm-again:hover { text-decoration: underline; }

@media (max-width: 560px) {
  .cmpm-row { grid-template-columns: 1fr; }
  .cmp-modal { padding: 1.5rem 1.25rem; }
}
/* Block printing of the analysis */
@media print {
  .cmp-modal-overlay { display: none !important; }
}
</style>

<script>
// ── Try-it-free modal: open/close ──────────────────────────────
const overlay = document.getElementById('cmpModal');
const formView = document.getElementById('cmpFormView');
const loadingView = document.getElementById('cmpLoadingView');
const resultsView = document.getElementById('cmpResultsView');

function showView(view) {
  [formView, loadingView, resultsView].forEach(v => v.hidden = v !== view);
}

function openModal() {
  overlay.hidden = false;
  document.body.style.overflow = 'hidden';
  showView(formView);
  document.getElementById('cmpmTitle').focus();
}
function closeModal() {
  overlay.hidden = true;
  document.body.style.overflow = '';
}

document.getElementById('cmpTryOpen')?.addEventListener('click', openModal);
document.getElementById('cmpModalClose')?.addEventListener('click', closeModal);
overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !overlay.hidden) closeModal(); });

// Block right-click and copy on the view-only results
resultsView?.addEventListener('contextmenu', (e) => e.preventDefault());
resultsView?.addEventListener('copy', (e) => e.preventDefault());

// ── Populate state select ──────────────────────────────────────
const STATES = {
  AL:0.88, AK:1.05, AZ:0.98, AR:0.86, CA:1.22, CO:1.08, CT:1.12, DE:1.02, FL:0.96, GA:0.97,
  HI:1.10, ID:0.92, IL:1.04, IN:0.91, IA:0.90, KS:0.90, KY:0.89, LA:0.90, ME:0.95, MD:1.08,
  MA:1.18, MI:0.95, MN:1.02, MS:0.85, MO:0.92, MT:0.91, NE:0.91, NV:0.99, NH:1.04, NJ:1.14,
  NM:0.90, NY:1.20, NC:0.97, ND:0.93, OH:0.93, OK:0.88, OR:1.05, PA:1.00, RI:1.03, SC:0.92,
  SD:0.89, TN:0.94, TX:1.00, UT:0.98, VT:0.97, VA:1.05, WA:1.15, WV:0.85, WI:0.95, WY:0.92, DC:1.25,
};
const stateSel = document.getElementById('cmpmState');
Object.keys(STATES).forEach(s => {
  const o = document.createElement('option');
  o.value = s; o.textContent = s;
  stateSel.appendChild(o);
});

// ── Model pill selection ────────────────────────────────────────
let selectedModel = 'general';
document.querySelectorAll('.cmpm-model').forEach(pill => {
  pill.addEventListener('click', () => {
    document.querySelectorAll('.cmpm-model').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    selectedModel = pill.dataset.model;
  });
});

// ── Sample analysis engine (client-side demonstration model) ───
const ROLE_BASES = [
  [/chief|cxo|ceo|cfo|coo|cto/, 195000], [/vice president|vp /, 165000], [/director/, 138000],
  [/software|developer|engineer(?!.*(service|maintenance))/, 108000], [/physician|doctor|md\b/, 220000],
  [/attorney|lawyer|counsel/, 132000], [/pharmacist/, 125000], [/data scien/, 118000],
  [/product manager/, 122000], [/architect/, 115000], [/registered nurse|rn\b/, 84000],
  [/nurse practitioner/, 118000], [/lpn|licensed practical/, 54000], [/medical assistant/, 42000],
  [/accountant|controller/, 82000], [/financial analyst/, 85000], [/analyst/, 78000],
  [/marketing manager/, 92000], [/marketing/, 72000], [/sales manager/, 98000],
  [/account executive|sales rep/, 72000], [/sales/, 68000], [/hr manager|human resources manager/, 88000],
  [/hr |human resource|recruiter/, 68000], [/designer/, 76000], [/project manager/, 92000],
  [/operations manager/, 86000], [/manager/, 82000], [/supervisor/, 66000],
  [/electrician|plumber|hvac/, 64000], [/mechanic|technician/, 56000], [/driver/, 52000],
  [/chef|culinary/, 58000], [/cook/, 38000], [/server|waiter|waitress|bartender/, 34000],
  [/cashier|retail associate/, 32000], [/administrative|admin assistant|receptionist/, 44000],
  [/teacher|instructor/, 56000], [/agent|producer/, 62000], [/coordinator/, 52000],
];
const EXP_MULT = { '0-2': 0.85, '3-5': 1.0, '5-8': 1.12, '8-12': 1.25, '12+': 1.38 };
const SIZE_MULT = { '1-10': 0.92, '11-50': 1.0, '51-200': 1.06, '201-500': 1.10, '500+': 1.15 };
const MODEL_ADJ = {
  general:    { mult: 1.0,  note: 'General model blends job postings, company career sites, and BLS OEWS data.' },
  healthcare: { mult: 1.06, note: 'Healthcare model factors license premiums and shift differentials into total comp.' },
  insurance:  { mult: 1.03, note: 'Insurance model reflects producer base + commission structures; renewals can add 15–40% on top.' },
  sales:      { mult: 1.02, note: 'Sales model shows base salary; typical OTE for quota-carrying roles is 1.7–2.1× base.' },
  realestate: { mult: 1.0,  note: 'Real Estate model: for commissioned agents, GCI after split matters more than base — full model available on signup.' },
  restaurants:{ mult: 0.92, note: 'Restaurants model accounts for tip credit and FOH/BOH structures; tips can add 30–80% for FOH roles.' },
};

function hashStr(s) {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;
  return h;
}
function fmt(n) {
  return '$' + (Math.round(n / 500) * 500).toLocaleString('en-US');
}
function fmtHr(n) {
  return '$' + (n / 2080).toFixed(2) + '/hr';
}

function runAnalysis() {
  const title = document.getElementById('cmpmTitle').value.trim();
  const city = document.getElementById('cmpmCity').value.trim();
  const state = stateSel.value;
  const exp = document.getElementById('cmpmExp').value;
  const size = document.getElementById('cmpmSize').value;
  const err = document.getElementById('cmpmError');

  if (!title || !state) { err.hidden = false; return; }
  err.hidden = true;

  showView(loadingView);

  setTimeout(() => {
    const t = title.toLowerCase();
    let base = 62000;
    for (const [re, val] of ROLE_BASES) { if (re.test(t)) { base = val; break; } }
    if (/senior|sr\.?|lead|principal/.test(t)) base *= 1.18;
    if (/junior|jr\.?|entry/.test(t)) base *= 0.85;

    const jitter = 0.97 + (hashStr(t + state + city) % 700) / 10000; // ±3%
    const median = base * STATES[state] * EXP_MULT[exp] * SIZE_MULT[size] * MODEL_ADJ[selectedModel].mult * jitter;

    document.getElementById('cmprRole').textContent = title;
    document.getElementById('cmprMeta').textContent =
      (city ? city + ', ' : '') + state + ' · ' + exp + ' yrs experience · ' + size + ' employees · ' +
      selectedModel.charAt(0).toUpperCase() + selectedModel.slice(1) + ' model';

    const bands = [
      { name: 'Observed range', lo: median * 0.82, hi: median * 1.18, cls: '' },
      { name: 'Likely market', lo: median * 0.90, hi: median * 1.10, cls: 'likely' },
      { name: 'Competitive offer', lo: median * 1.08, hi: median * 1.22, cls: '' },
    ];
    document.getElementById('cmprBands').innerHTML = bands.map(b => `
      <div class="cmpm-band ${b.cls}">
        <div class="cmpm-band-name">${b.name}</div>
        <div class="cmpm-band-range">${fmt(b.lo)} – ${fmt(b.hi)}</div>
        <div class="cmpm-band-hourly">${fmtHr(b.lo)} – ${fmtHr(b.hi)}</div>
      </div>`).join('');

    const h = hashStr(state + t);
    const signals = [
      'Demand for this role is trending up in this market — postings rose over the last quarter.',
      'Market demand for this role is steady; ranges have held within ±3% this quarter.',
      'This market is competitive — similar roles are filling in under 30 days.',
    ];
    const insights = [
      signals[h % signals.length],
      MODEL_ADJ[selectedModel].note,
      'Sample estimate from the Kixlogic CMP methodology. Full analyses use live posting, career-site, and BLS OEWS data.',
    ];
    document.getElementById('cmprInsights').innerHTML = insights.map(i => `<li>${i}</li>`).join('');

    showView(resultsView);
  }, 900);
}

document.getElementById('cmpmRun')?.addEventListener('click', runAnalysis);
document.getElementById('cmpmAgain')?.addEventListener('click', () => showView(formView));
</script>
