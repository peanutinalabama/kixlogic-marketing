---
import Base from '../layouts/Base.astro';

const atsPlans = [
  {
    id: 'starter',
    name: 'Starter',
    price: '49',
    period: 'per month',
    desc: 'For a single recruiter or small team just getting started with structured hiring.',
    featured: false,
    cta: 'Get Started',
    ctaStyle: 'outline',
    features: [
      { ok: true, text: '2 active job postings' },
      { ok: true, text: '1 Admin + 1 Recruiter seat' },
      { ok: true, text: 'White-label careers page' },
      { ok: true, text: '8-stage kanban pipeline' },
      { ok: true, text: 'Search-engine job result eligible*' },
      { ok: true, text: 'Application auto-reply w/ merge tags' },
      { ok: true, text: 'Mobile-ready forms' },
      { ok: true, text: 'CSV export' },
      { ok: true, text: 'Applicant source tracking' },
      { ok: true, text: 'Talent community pool' },
      { ok: true, text: 'Advanced analytics dashboard' },
      { ok: true, text: 'Activity log audit trail' },
      { ok: true, text: 'Job cloning, reopen, close cascade' },
      { ok: true, text: 'Per-tenant SMTP (Yahoo/Gmail/O365)' },
      { ok: false, text: 'AI features' },
      { ok: false, text: 'Interview scheduling' },
      { ok: false, text: 'Employee referral portal' },
      { ok: false, text: 'Offer letters & onboarding' },
    ],
  },
  {
    id: 'growth',
    name: 'Growth',
    price: '129',
    period: 'per month',
    desc: 'For growing teams ready to layer AI and automation on top of their hiring process.',
    featured: false,
    cta: 'Start Free Trial',
    ctaStyle: 'outline',
    features: [
      { ok: true, text: '10 active job postings' },
      { ok: true, text: '1 Admin + 5 Recruiter seats' },
      { ok: true, text: 'Everything in Starter' },
      { ok: true, text: 'AI resume scoring (200/mo)', highlight: true },
      { ok: true, text: 'AI job description builder', highlight: true },
      { ok: true, text: 'AI resume search (natural language)', highlight: true },
      { ok: true, text: 'AI setup assistant in-dashboard', highlight: true },
      { ok: true, text: 'Rejection email workflow w/ reason codes', highlight: true },
      { ok: true, text: 'Welcome email template on hire', highlight: true },
      { ok: true, text: 'Forward to hiring manager', highlight: true },
      { ok: true, text: 'Employee referral portal', highlight: true },
      { ok: true, text: 'Interview scheduling + calendar invites', highlight: true },
      { ok: true, text: 'Talent community matching', highlight: true },
      { ok: true, text: 'Custom color schemes + advanced branding', highlight: true },
      { ok: false, text: 'Offer letters & e-signature' },
      { ok: false, text: 'Onboarding portal' },
      { ok: false, text: 'AI Salary Intelligence' },
    ],
  },
  {
    id: 'professional',
    name: 'Professional',
    price: '249',
    period: 'per month',
    desc: 'For established HR teams ready to automate the full employee lifecycle from offer through onboarding.',
    featured: true,
    badge: 'Most Popular',
    cta: 'Start Free Trial',
    ctaStyle: 'primary',
    features: [
      { ok: true, text: 'Unlimited job postings' },
      { ok: true, text: 'Unlimited seats' },
      { ok: true, text: 'Everything in Growth' },
      { ok: true, text: 'Kixlogic CMP included (500 CIUs/month)', highlight: true },
      { ok: true, text: 'Candidate Sourcing platform integration', highlight: true },
      { ok: true, text: 'AI resume scoring (750/mo)', highlight: true },
      { ok: true, text: 'Applicant SMS texting (2,000/mo)', highlight: true },
      { ok: true, text: 'Offer letter templates, send & e-signature', highlight: true },
      { ok: true, text: 'Offer approval workflow (internal reviewer)', highlight: true },
      { ok: true, text: 'Candidate offer portal + e-signature', highlight: true },
      { ok: true, text: 'Onboarding packet builder (multi-doc)', highlight: true },
      { ok: true, text: 'Candidate onboarding portal + e-signature', highlight: true },
      { ok: true, text: 'Custom reports (build, save, run)', highlight: true },
      { ok: true, text: 'Scheduled CSV report delivery', highlight: true },
      { ok: true, text: 'AI Salary Intelligence (BLS + regional)', highlight: true },
      { ok: true, text: 'Per-applicant document library', highlight: true },
      { ok: true, text: 'XML job feeds for Indeed + aggregators', highlight: true },
      { ok: true, text: 'Advanced analytics dashboard', highlight: true },
      { ok: true, text: 'Priority support (24-hr response)', highlight: true },
    ],
  },
  {
    id: 'enterprise',
    name: 'Enterprise',
    price: 'Custom',
    period: 'contact us',
    desc: 'For large organizations that need unlimited scale with dedicated support.',
    featured: false,
    customPrice: true,
    cta: 'Contact Sales',
    ctaStyle: 'outline',
    ctaHref: '/contact',
    hideFeatures: true,
    features: [],
  },
];

const cmpPlans = [
  {
    id: 'cmp-essentials',
    name: 'Essentials',
    price: '49',
    period: 'per month',
    ciUs: '100',
    desc: 'Occasional hiring — benchmarks, offers, and job descriptions.',
    featured: false,
    cta: 'Get Started',
    ctaStyle: 'outline',
    features: [
      { ok: true, text: 'Unlimited HR users' },
      { ok: true, text: '100 CIUs/month' },
      { ok: true, text: 'Merit cycles (employee import, pool budgeting, approval chains)' },
      { ok: true, text: 'Deals & policies tracking' },
      { ok: true, text: 'Earnings ledger' },
      { ok: true, text: 'Commission tools (rules engine, forecasting, simulator)' },
      { ok: true, text: 'Salary benchmark (General model)' },
      { ok: true, text: 'Offer analyzer' },
      { ok: true, text: 'Job description builder' },
      { ok: false, text: 'Healthcare, Insurance, Sales, Real Estate, Restaurants models' },
      { ok: false, text: 'Internal pay equity analysis' },
      { ok: false, text: 'Compensation strategy report' },
    ],
  },
  {
    id: 'cmp-growth',
    name: 'Growth',
    price: '149',
    period: 'per month',
    ciUs: '500',
    desc: 'Active hiring — multiple roles and offer cycles each month.',
    featured: true,
    badge: 'Most popular',
    cta: 'Get Started',
    ctaStyle: 'primary',
    features: [
      { ok: true, text: 'Unlimited HR users' },
      { ok: true, text: '500 CIUs/month' },
      { ok: true, text: 'Everything in Essentials' },
      { ok: true, text: 'Industry model add-ons (Healthcare, Insurance, Sales, Real Estate, Restaurants)', highlight: true },
      { ok: true, text: 'Internal pay equity analysis', highlight: true },
      { ok: true, text: 'Pay compression analysis', highlight: true },
      { ok: true, text: 'Compensation strategy report', highlight: true },
      { ok: true, text: 'Merit cycle AI pay letters', highlight: true },
      { ok: true, text: 'Advanced spend reports', highlight: true },
      { ok: false, text: 'CIU top-up packs at volume rates' },
      { ok: false, text: 'Custom CIU allotments' },
      { ok: false, text: 'Dedicated support' },
    ],
  },
  {
    id: 'cmp-professional',
    name: 'Professional',
    price: '399',
    period: 'per month',
    ciUs: '2000',
    desc: 'Heavy usage — merit cycles, recruiting strategy, vertical models.',
    featured: false,
    cta: 'Get Started',
    ctaStyle: 'outline',
    features: [
      { ok: true, text: 'Unlimited HR users' },
      { ok: true, text: '2,000 CIUs/month' },
      { ok: true, text: 'Everything in Growth' },
      { ok: true, text: 'Unlimited industry model depth', highlight: true },
      { ok: true, text: 'All hiring + compensation tools', highlight: true },
      { ok: true, text: 'Commission audit (Real Estate)' },
      { ok: true, text: 'Producer comp optimizer (Insurance)' },
      { ok: true, text: 'Sales comp optimization (Sales)' },
      { ok: true, text: 'Tip pool simulator (Restaurants)' },
      { ok: true, text: 'Priority support', highlight: true },
      { ok: false, text: 'SSO' },
      { ok: false, text: 'Custom contract & SLA' },
    ],
  },
];

const atsFaqs = [
  {
    q: 'What happens after the 14-day trial?',
    a: "You'll choose a plan and enter your billing details. If you don't, your account pauses — your data is safe and you can reactivate anytime.",
  },
  {
    q: 'Can I switch plans later?',
    a: 'Yes, anytime. Upgrade from Starter to Growth or Professional and you\'ll get access to AI scoring, advanced analytics, and more — effective immediately.',
  },
  {
    q: 'Is my applicant data secure?',
    a: 'Yes. Data is encrypted in transit and at rest. Our web infrastructure is protected by Cloudflare, including DDoS mitigation, Web Application Firewall, and SSL/TLS attack protection.',
  },
  {
    q: 'Do I need to install any software?',
    a: 'No. Kixlogic is 100% cloud-based — sign up, configure your branding, and your careers page and ATS dashboard are live in under 10 minutes from any browser.',
  },
];

const cmpFaqs = [
  {
    q: 'What is a CIU?',
    a: 'A CIU (Compensation Intelligence Unit) is one analysis — a salary benchmark, offer analysis, job description builder run, or AI hiring tool. You pay for decisions, not compute. Your plan includes a monthly CIU allotment; overage packs available anytime.',
  },
  {
    q: 'Can I switch plans later?',
    a: 'Yes, anytime. Upgrade or downgrade your plan and adjust your CIU allotment to match your hiring volume — changes take effect immediately.',
  },
  {
    q: 'Are industry model add-ons required?',
    a: 'No. Every account includes the General model for any role, any industry. Industry models (Healthcare, Insurance, Sales, Real Estate, Restaurants) are optional add-ons for specialized benchmarks and tools.',
  },
  {
    q: 'Is my compensation data secure?',
    a: 'Yes. All employee and compensation data is encrypted in transit and at rest. Our infrastructure is protected by Cloudflare with DDoS mitigation, Web Application Firewall, and SSL/TLS protection.',
  },
];
---
<Base
  title="Pricing"
  description="Kixlogic ATS pricing for small and mid-sized businesses. Four plans starting at $49/month. 14-day free trial on Growth and Professional."
>
  <section class="pricing-page section">
    <div class="container">
      <div class="pricing-header">
        <span class="tag">✦ Simple, transparent pricing</span>
        <h1>Pay for what you need</h1>
        <p>Choose Kixlogic ATS for hiring, Kixlogic CMP for compensation intelligence, or use both together.</p>
      </div>

      <div class="pricing-tabs">
        <button class="pricing-tab active" data-tab="ats">Kixlogic ATS</button>
        <button class="pricing-tab" data-tab="cmp">Kixlogic CMP</button>
      </div>

      <div class="pricing-tab-content active" id="ats-tab">
        <p class="pricing-tab-desc">Four plans for hiring teams of any size. Growth and Professional include a <strong>14-day free trial</strong>.</p>
        <div class="pricing-grid">
          {atsPlans.map(plan => (
          <div class={`pricing-card card ${plan.featured ? 'featured' : ''}`}>
            {plan.badge && <div class="pricing-badge">{plan.badge}</div>}
            <div class="pricing-plan">{plan.name}</div>
            <div class={`pricing-price ${plan.customPrice ? 'custom' : ''}`}>
              {!plan.customPrice && <><sup>$</sup>{plan.price}<sup class="tax">†</sup></>}
              {plan.customPrice && plan.price}
            </div>
            <div class="pricing-period">
              {plan.period === 'contact us' ? (
                <>Contact <a href="/contact/" class="contact-link">Kixlogic</a> for a quote</>
              ) : (
                plan.period
              )}
            </div>
            <p class="pricing-desc">{plan.desc}</p>
            {!plan.hideFeatures && (
              <>
                <div class="pricing-divider"></div>
                <ul class="pricing-features">
                  {plan.features.map(f => (
                    <li class={`pricing-feature ${f.ok ? 'active' : ''} ${f.highlight ? 'highlight' : ''}`}>
                      <span class={f.ok ? 'check' : 'x'}>{f.ok ? '✓' : '✗'}</span>
                      {f.text}
                    </li>
                  ))}
                </ul>
              </>
            )}
            {plan.ctaHref ? (
              <a href={plan.ctaHref} class={`pricing-cta ${plan.ctaStyle === 'primary' ? 'pricing-cta-primary' : 'pricing-cta-outline'}`}>
                {plan.cta}
              </a>
            ) : (
              <button type="button" data-checkout={plan.id} class={`pricing-cta ${plan.ctaStyle === 'primary' ? 'pricing-cta-primary' : 'pricing-cta-outline'}`}>
                {plan.cta}
              </button>
            )}
          </div>
          ))}
        </div>

        <p class="pricing-note">
          Growth and Professional plans include a <span>14-day free trial</span>. Card required — cancel before trial ends and pay nothing. AI scoring overages billed at $0.15/application.
        </p>
      </div>

      <div class="pricing-tab-content" id="cmp-tab">
        <p class="pricing-tab-desc">Platform subscription + CIUs for AI compensation analyses. All plans include merit cycles, earnings tracking, and commission tools.</p>
        <div class="pricing-grid three-col">
          {cmpPlans.map(plan => (
            <div class={`pricing-card card ${plan.featured ? 'featured' : ''}`}>
              {plan.badge && <div class="pricing-badge">{plan.badge}</div>}
              <div class="pricing-plan">{plan.name}</div>
              <div class="pricing-price"><sup>$</sup>{plan.price}<sup class="tax">†</sup></div>
              <div class="pricing-period">{plan.period}</div>
              <div class="ciu-amount">{plan.ciUs} CIUs/month</div>
              <p class="pricing-desc">{plan.desc}</p>
              <div class="pricing-divider"></div>
              <ul class="pricing-features">
                {plan.features.map(f => (
                  <li class={`pricing-feature ${f.ok ? 'active' : ''} ${f.highlight ? 'highlight' : ''}`}>
                    <span class={f.ok ? 'check' : 'x'}>{f.ok ? '✓' : '✗'}</span>
                    {f.text}
                  </li>
                ))}
              </ul>
              <button type="button" data-checkout={plan.id} class={`pricing-cta ${plan.ctaStyle === 'primary' ? 'pricing-cta-primary' : 'pricing-cta-outline'}`}>
                {plan.cta}
              </button>
            </div>
          ))}
        </div>

        <p class="pricing-note">
          All plans include merit cycles, earnings ledger, and commission tools — no CIUs required. New accounts get <strong>5 free CIUs</strong> to try.
        </p>
      </div>
      <p class="pricing-tax-note">
        <sup>†</sup> Prices shown are base subscription rates in U.S. dollars and do not include applicable taxes. Taxes calculated at checkout based on your billing address.
      </p>

      <div class="faq-wrap" id="ats-faq">
        <h2>Frequently asked</h2>
        {atsFaqs.map(f => (
          <details>
            <summary>{f.q}</summary>
            <div class="faq-body">{f.a}</div>
          </details>
        ))}
      </div>

      <div class="faq-wrap" id="cmp-faq" style="display: none;">
        <h2>Frequently asked</h2>
        {cmpFaqs.map(f => (
          <details>
            <summary>{f.q}</summary>
            <div class="faq-body">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
.pricing-page { padding-top: 5rem; }
.pricing-header { text-align: center; margin-bottom: 3rem; }
.pricing-header .tag { margin-bottom: 1rem; }
.pricing-header h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
}
.pricing-header p {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 640px;
  margin: 0 auto;
  line-height: 1.6;
}
.pricing-header strong { color: var(--gold); }

.wip-banner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 0.75rem 1.25rem;
  background: linear-gradient(135deg, rgba(20,184,148,0.08), rgba(99,102,241,0.08));
  border: 1px solid var(--border-gold);
  border-radius: var(--radius-lg);
  padding: 1rem 1.5rem;
  margin-bottom: 2rem;
  max-width: 720px;
  margin-left: auto;
  margin-right: auto;
}
.wip-banner p { font-size: 0.9rem; color: var(--text-muted); margin: 0; flex: 1; min-width: 200px; text-align: left; }
.wip-banner strong { color: var(--text); }
.wip-link { font-size: 0.85rem; font-weight: 700; color: var(--gold); white-space: nowrap; }

.pricing-tabs {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin: 2rem 0 2.5rem;
}
.pricing-tab {
  padding: 0.65rem 1.5rem;
  border-radius: var(--radius-pill);
  border: 1px solid var(--border);
  background: #fff;
  color: var(--text);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
}
.pricing-tab:hover { border-color: var(--ms-blue); }
.pricing-tab.active {
  background: var(--ms-blue);
  color: #fff;
  border-color: var(--ms-blue);
}
.pricing-tab-content { display: none; }
.pricing-tab-content.active { display: block; }
.pricing-tab-desc {
  text-align: center;
  font-size: 0.95rem;
  color: var(--text-muted);
  margin-bottom: 2rem;
  max-width: 640px;
  margin-left: auto;
  margin-right: auto;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}
.pricing-grid.three-col {
  grid-template-columns: repeat(3, 1fr);
}
.pricing-card { position: relative; display: flex; flex-direction: column; padding: 1.5rem; }
.pricing-card.featured {
  border-color: var(--border-gold);
  background: linear-gradient(135deg, rgba(20,184,148,0.06), var(--surface));
  box-shadow: 0 0 60px rgba(20,184,148,0.1);
}
.pricing-badge {
  position: absolute;
  top: -13px; left: 50%; transform: translateX(-50%);
  background: var(--gold); color: var(--navy);
  padding: 0.25rem 1rem; border-radius: 99px;
  font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
  white-space: nowrap;
}
.pricing-plan {
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.875rem;
  text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); margin-bottom: 0.75rem;
}
.pricing-card.featured .pricing-plan { color: var(--gold); }
.pricing-price {
  font-family: 'Syne', sans-serif; font-weight: 800; font-size: 3rem;
  color: var(--text); line-height: 1; margin-bottom: 0.25rem; letter-spacing: -2px;
}
.pricing-price.custom { font-size: 2rem; padding-top: 0.5rem; }
.pricing-price sup { font-size: 1.5rem; vertical-align: super; }
.pricing-price sup.tax { font-size: 0.5em; }
.pricing-period { font-size: 0.825rem; color: var(--text-muted); margin-bottom: 0.5rem; }
.pricing-period a.contact-link { color: var(--ms-blue); font-weight: 600; text-decoration: none; }
.pricing-period a.contact-link:hover { text-decoration: underline; }
.ciu-amount { font-size: 0.9rem; font-weight: 600; color: var(--ms-blue); margin-bottom: 1rem; }
.pricing-desc { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1.75rem; line-height: 1.5; }
.pricing-divider { height: 1px; background: var(--border); margin-bottom: 1.5rem; }
.pricing-features { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 2rem; flex: 1; }
.pricing-feature { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.875rem; color: var(--text-dim); }
.pricing-feature.active { color: var(--text-muted); }
.pricing-feature.highlight { color: var(--gold); }
.pricing-feature .check { color: var(--gold); flex-shrink: 0; }
.pricing-feature .x { color: var(--text-dim); flex-shrink: 0; }
.pricing-cta {
  width: 100%; padding: 0.85rem; border-radius: 10px;
  font-weight: 700; font-size: 0.95rem; text-align: center;
  transition: var(--transition); display: block;
  border: none; cursor: pointer; font-family: inherit;
}
.pricing-cta-primary { background: var(--gold); color: var(--navy); }
.pricing-cta-primary:hover { background: var(--gold-light); box-shadow: 0 8px 25px rgba(20,184,148,0.3); }
.pricing-cta-outline { background: transparent; color: var(--text); border: 1.5px solid var(--border); }
.pricing-cta-outline:hover { border-color: var(--border-gold); background: var(--gold-dim); }

.pricing-note {
  text-align: center; margin-top: 2rem;
  font-size: 0.825rem; color: var(--text-dim);
  max-width: 800px; margin-left: auto; margin-right: auto; line-height: 1.7;
}
.pricing-note span { color: var(--gold); }
.pricing-tax-note {
  text-align: center; margin-top: 0.85rem;
  font-size: 0.75rem; color: var(--text-dim);
}

.faq-wrap { max-width: 760px; margin: 5rem auto 0; }
.faq-wrap h2 {
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.5rem;
  text-align: center; margin-bottom: 2rem;
}
details {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); margin-bottom: 0.75rem; overflow: hidden;
}
details[open] { border-color: var(--border-gold); }
summary {
  padding: 1.1rem 1.4rem; cursor: pointer;
  font-weight: 600; font-size: 0.925rem; color: var(--text);
  list-style: none; display: flex; justify-content: space-between; align-items: center;
}
summary::-webkit-details-marker { display: none; }
summary::after { content: '+'; font-size: 1.4rem; color: var(--gold); font-weight: 300; }
details[open] summary::after { content: '−'; }
.faq-body { padding: 0 1.4rem 1.25rem; font-size: 0.875rem; color: var(--text-muted); line-height: 1.7; }

@media (max-width: 1024px) {
  .pricing-grid { grid-template-columns: repeat(2, 1fr); }
  .pricing-grid.three-col { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .pricing-grid { grid-template-columns: 1fr; }
  .pricing-grid.three-col { grid-template-columns: 1fr; }
  .pricing-tabs { flex-direction: column; gap: 0.5rem; }
  .pricing-tab { width: 100%; }
}
</style>

<script>
document.querySelectorAll('.pricing-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const tabName = tab.dataset.tab;

    document.querySelectorAll('.pricing-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.pricing-tab-content').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.faq-wrap').forEach(f => f.style.display = 'none');

    tab.classList.add('active');
    document.getElementById(tabName + '-tab').classList.add('active');
    document.getElementById(tabName + '-faq').style.display = 'block';
  });
});
</script>
