---
let posts: any[] = [];
try {
  const res = await fetch('https://api.kixlogic.com/api/blog/posts-public');
  if (res.ok) {
    const data = await res.json();
    posts = (Array.isArray(data.posts) ? data.posts : [])
      .filter((p: any) => p.published_at)
      .sort((a: any, b: any) => new Date(b.published_at).valueOf() - new Date(a.published_at).valueOf())
      .slice(0, 3);
  }
} catch {
  posts = [];
}
---
{posts.length > 0 && (
  <section class="section section-grey" id="blog">
    <div class="container">
      <div class="blog-teaser-header">
        <h2 class="section-heading">From the blog</h2>
        <a href="/blog/" class="blog-teaser-link">View all posts →</a>
      </div>
      <div class="blog-teaser-grid">
        {posts.map((post: any) => {
          const dt = new Date(post.published_at);
          const date = dt.toLocaleDateString('en-US', {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}/`} class="blog-teaser-card">
              <time datetime={dt.toISOString()}>{date}</time>
              <h3>{post.title}</h3>
              <p>{post.excerpt || post.meta_description || ''}</p>
              <span class="blog-teaser-cta">Read article →</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}

<style>
.blog-teaser-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.blog-teaser-link {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--ms-blue);
}
.blog-teaser-link:hover { text-decoration: underline; }
.blog-teaser-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}
.blog-teaser-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  transition: box-shadow var(--transition), border-color var(--transition);
}
.blog-teaser-card:hover {
  border-color: var(--ms-blue);
  box-shadow: var(--shadow-hover);
}
.blog-teaser-card time {
  font-size: 0.75rem;
  color: var(--text-muted);
}
.blog-teaser-card h3 {
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.35;
}
.blog-teaser-card p {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.55;
  flex: 1;
}
.blog-teaser-cta {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--ms-blue);
  margin-top: 0.25rem;
}
@media (max-width: 900px) {
  .blog-teaser-grid { grid-template-columns: 1fr; }
}
</style>
