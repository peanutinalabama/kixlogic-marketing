---
const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname === path || pathname.startsWith(path + '/');

const links = [
  { href: '/ats/', label: 'Kixlogic ATS' },
  { href: '/compensation/', label: 'Kixlogic CMP' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/about/', label: 'About' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contact/', label: 'Contact' },
];
---

<header id="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="Kixlogic home">
      <img src="/kixlogic-logo.svg" alt="Kixlogic" height="44" />
    </a>

    <nav class="nav-links" id="navLinks" aria-label="Main">
      {links.map(l => (
        <a href={l.href} class={`nav-link ${isActive(l.href.replace(/\/$/, '') || '/') ? 'active' : ''}`}>{l.label}</a>
      ))}
    </nav>

    <div class="nav-utils">
      <div class="nav-signin" id="navSignin">
        <button class="nav-signin-btn" id="signinToggle" aria-haspopup="true" aria-expanded="false">
          Sign in
          <svg class="nav-signin-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="nav-signin-menu" id="signinMenu" hidden>
          <div class="nav-signin-label">Choose an app</div>
          <a href="https://app.kixlogic.com/dashboard" class="nav-signin-item">
            <span class="nav-signin-emoji">💼</span>
            <span class="nav-signin-text"><strong>Kixlogic ATS</strong><small>Hiring &amp; recruiting</small></span>
          </a>
          <a href="https://cmp.kixlogic.com/" class="nav-signin-item">
            <span class="nav-signin-emoji">📊</span>
            <span class="nav-signin-text"><strong>Kixlogic CMP</strong><small>Compensation intelligence</small></span>
          </a>
        </div>
      </div>
      <a href="/contact/" class="nav-util" aria-label="Contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L21 21" stroke-linecap="round"/></svg>
      </a>
      <button class="nav-hamburger" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</header>

<div class="nav-mobile" id="mobileMenu" hidden>
  <div class="container nav-mobile-inner">
    {links.map(l => (
      <a href={l.href} class="nav-mobile-link">{l.label}</a>
    ))}
  </div>
</div>

<style>
#nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fff;
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  display: flex;
  align-items: center;
  height: 72px;
  gap: 1.5rem;
}
.nav-logo { flex-shrink: 0; display: flex; align-items: center; }
.nav-logo img { height: 44px; width: auto; display: block; }

.nav-links {
  display: flex;
  align-items: center;
  gap: 0;
  flex: 1;
}
.nav-link {
  padding: 0.5rem 0.75rem;
  font-size: 0.8125rem;
  color: var(--text);
  border-bottom: 2px solid transparent;
  transition: border-color var(--transition), color var(--transition);
}
.nav-link:hover { border-bottom-color: var(--border); }
.nav-link.active { border-bottom-color: var(--ms-blue); }

.nav-utils {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-left: auto;
}
.nav-util {
  display: flex;
  align-items: center;
  color: var(--text);
  padding: 0.35rem;
  font-size: 0.8125rem;
  transition: color var(--transition);
}
.nav-util:hover { color: var(--ms-blue); }

/* Sign in dropdown */
.nav-signin { position: relative; }
.nav-signin-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.4rem 0.9rem;
  border: 1px solid var(--ms-blue);
  border-radius: var(--radius-pill);
  background: transparent;
  color: var(--ms-blue);
  font-family: inherit;
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: background var(--transition), color var(--transition);
}
.nav-signin-btn:hover { background: var(--ms-blue); color: #fff; }
.nav-signin-caret { transition: transform var(--transition); }
.nav-signin-btn[aria-expanded="true"] .nav-signin-caret { transform: rotate(180deg); }
.nav-signin-menu {
  position: absolute;
  top: calc(100% + 0.5rem);
  right: 0;
  min-width: 240px;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-hover);
  padding: 0.5rem;
  z-index: 200;
}
.nav-signin-menu[hidden] { display: none; }
.nav-signin-label {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-dim);
  padding: 0.4rem 0.6rem 0.5rem;
}
.nav-signin-item {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  padding: 0.6rem;
  border-radius: var(--radius);
  color: var(--text);
  transition: background var(--transition);
}
.nav-signin-item:hover { background: var(--navy-2); }
.nav-signin-emoji { font-size: 1.3rem; line-height: 1; }
.nav-signin-text { display: flex; flex-direction: column; }
.nav-signin-text strong { font-size: 0.875rem; font-weight: 600; }
.nav-signin-text small { font-size: 0.75rem; color: var(--text-muted); }

.nav-hamburger {
  display: none;
  background: none;
  border: none;
  color: var(--text);
  cursor: pointer;
  padding: 0.35rem;
}

.nav-mobile {
  background: #fff;
  border-bottom: 1px solid var(--border);
  padding: 0.75rem 0 1rem;
}
.nav-mobile[hidden] { display: none; }
.nav-mobile:not([hidden]) { display: block; }
.nav-mobile-inner { display: flex; flex-direction: column; gap: 0.25rem; }
.nav-mobile-link {
  padding: 0.65rem 0;
  font-size: 0.9375rem;
  color: var(--text);
  border-bottom: 1px solid var(--navy-2);
}
@media (max-width: 860px) {
  .nav-links { display: none; }
  .nav-hamburger { display: flex; }
}
</style>

<script>
const toggle = document.getElementById('navToggle');
const menu   = document.getElementById('mobileMenu');

toggle?.addEventListener('click', () => {
  const open = menu?.hasAttribute('hidden');
  if (open) {
    menu?.removeAttribute('hidden');
    toggle.setAttribute('aria-expanded', 'true');
  } else {
    menu?.setAttribute('hidden', '');
    toggle.setAttribute('aria-expanded', 'false');
  }
});

menu?.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    menu?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
  });
});

// Sign in app picker
const signinToggle = document.getElementById('signinToggle');
const signinMenu   = document.getElementById('signinMenu');
const signinWrap   = document.getElementById('navSignin');

const closeSignin = () => {
  signinMenu?.setAttribute('hidden', '');
  signinToggle?.setAttribute('aria-expanded', 'false');
};

signinToggle?.addEventListener('click', (e) => {
  e.stopPropagation();
  const open = signinMenu?.hasAttribute('hidden');
  if (open) {
    signinMenu?.removeAttribute('hidden');
    signinToggle.setAttribute('aria-expanded', 'true');
  } else {
    closeSignin();
  }
});

document.addEventListener('click', (e) => {
  if (signinWrap && !signinWrap.contains(e.target)) closeSignin();
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeSignin();
});
</script>
