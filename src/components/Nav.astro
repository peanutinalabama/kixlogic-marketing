---
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<nav id="nav">
  <div class="nav-inner container">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Kixlogic home">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="8" fill="#14B894"/>
        <path d="M8 8h4v16H8zM20 8l-6 8 6 8h4.5l-6-8 6-8H20z" fill="#061820"/>
      </svg>
      <span class="nav-logo-text">Kixlogic</span>
    </a>

    <!-- Primary nav -->
    <div class="nav-links" id="navLinks">
      <!-- Products dropdown -->
      <div class="nav-dropdown">
        <button class="nav-link nav-dropdown-btn" aria-expanded="false" aria-haspopup="true">
          Products
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="dropdown-chevron">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="nav-dropdown-panel" role="menu">
          <a href="/ats" role="menuitem" class="dropdown-item">
            <span class="dropdown-item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <rect x="3" y="4" width="18" height="16" rx="2" stroke="#14B894" stroke-width="1.5"/>
                <path d="M7 9h10M7 13h6" stroke="#14B894" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="17" cy="16" r="3" fill="#14B894" opacity=".3"/>
                <path d="M16 16l1 1 1.5-1.5" stroke="#14B894" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </span>
            <span>
              <strong>Kixlogic ATS</strong>
              <small>Applicant tracking for life sciences</small>
            </span>
          </a>
          <a href="/comp" role="menuitem" class="dropdown-item">
            <span class="dropdown-item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M3 17l4-4 4 4 4-6 4 3" stroke="#6366F1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="19" cy="5" r="3" fill="#6366F1" opacity=".3"/>
              </svg>
            </span>
            <span>
              <strong>Kixlogic Comp</strong>
              <small>Compensation intelligence</small>
            </span>
          </a>
        </div>
      </div>

      <a href="/blog"    class={`nav-link ${isActive('/blog')    ? 'active' : ''}`}>Blog</a>
      <a href="/pricing" class={`nav-link ${isActive('/pricing') ? 'active' : ''}`}>Pricing</a>
      <a href="/about"   class={`nav-link ${isActive('/about')   ? 'active' : ''}`}>About</a>
    </div>

    <!-- Right actions -->
    <div class="nav-actions">
      <a href="https://app.kixlogic.com/dashboard" class="nav-signin">Sign in</a>
      <a href="https://app.kixlogic.com/dashboard" class="btn btn-primary nav-cta">Get started</a>
    </div>

    <!-- Hamburger -->
    <button class="nav-hamburger" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
#nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(6, 24, 32, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.nav-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 64px;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  flex-shrink: 0;
}
.nav-logo-text {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.15rem;
  color: #F0F4FF;
  letter-spacing: -0.02em;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
}
.nav-link {
  padding: 0.5rem 0.875rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: #7ABFCC;
  border-radius: 8px;
  transition: color 0.2s, background 0.2s;
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  display: flex;
  align-items: center;
  gap: 0.3rem;
}
.nav-link:hover,
.nav-link.active { color: #F0F4FF; background: rgba(255,255,255,0.06); }

.nav-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-left: auto;
  flex-shrink: 0;
}
.nav-signin {
  font-size: 0.9rem;
  font-weight: 500;
  color: #7ABFCC;
  padding: 0.5rem 0.75rem;
  border-radius: 8px;
  transition: color 0.2s;
}
.nav-signin:hover { color: #F0F4FF; }
.nav-cta {
  font-size: 0.875rem;
  padding: 0.5rem 1.25rem;
}

/* Dropdown */
.nav-dropdown { position: relative; }
.nav-dropdown-btn { gap: 0.3rem; }
.dropdown-chevron { transition: transform 0.2s; }
.nav-dropdown:hover .dropdown-chevron,
.nav-dropdown-btn[aria-expanded="true"] .dropdown-chevron { transform: rotate(180deg); }

.nav-dropdown-panel {
  position: absolute;
  top: calc(100% + 0.75rem);
  left: 0;
  min-width: 260px;
  background: #0A2030;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 0.625rem;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-6px);
  transition: opacity 0.2s, transform 0.2s;
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}
.nav-dropdown:hover .nav-dropdown-panel,
.nav-dropdown-btn[aria-expanded="true"] + .nav-dropdown-panel {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
.dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 0.75rem 0.875rem;
  border-radius: 10px;
  transition: background 0.15s;
}
.dropdown-item:hover { background: rgba(255,255,255,0.06); }
.dropdown-item strong { display: block; font-size: 0.9rem; color: #F0F4FF; font-weight: 600; }
.dropdown-item small  { display: block; font-size: 0.78rem; color: #7ABFCC; margin-top: 2px; }
.dropdown-item-icon {
  width: 38px; height: 38px;
  background: rgba(255,255,255,0.06);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

/* Hamburger */
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  margin-left: auto;
}
.nav-hamburger span {
  display: block;
  width: 22px; height: 2px;
  background: #F0F4FF;
  border-radius: 2px;
  transition: 0.2s;
}

@media (max-width: 768px) {
  .nav-hamburger { display: flex; }
  .nav-links, .nav-actions { display: none; }
  .nav-links.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 64px;
    left: 0; right: 0;
    background: #0A2030;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 1rem 1.5rem;
    gap: 0.5rem;
    z-index: 99;
  }
  .nav-links.open + .nav-actions {
    display: flex;
    position: absolute;
    top: calc(64px + 8rem);
    left: 1.5rem; right: 1.5rem;
    background: #0A2030;
    padding: 1rem;
    flex-direction: column;
    z-index: 99;
  }
  .nav-dropdown-panel {
    position: static;
    opacity: 1;
    pointer-events: auto;
    transform: none;
    box-shadow: none;
    background: rgba(255,255,255,0.04);
    border: none;
    padding: 0.5rem 0 0.5rem 1rem;
  }
}
</style>

<script>
const toggle = document.getElementById('navToggle');
const links  = document.getElementById('navLinks');
toggle?.addEventListener('click', () => {
  const open = links?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
});
</script>
