---
import type { HomepageData } from '../lib/cms-types';

interface Props {
  data: HomepageData;
}

const { data } = Astro.props;
const sections = data.sections.filter(s => s.enabled !== false);
---
{data.greeting && (
  <section class="ms-greeting">
    <div class="container greeting-inner">
      <h1>{data.greeting.headline}</h1>
      <p class="greeting-sub">{data.greeting.subheadline}</p>
      <div class="segment-toggle" role="tablist">
        <button type="button" class="segment active" data-segment="business">For business</button>
        <button type="button" class="segment" data-segment="personal">For hiring teams</button>
      </div>
      {data.greeting.buttons?.length > 0 && (
        <div class="greeting-actions">
          {data.greeting.buttons.map(btn => (
            <a href={btn.href} class="btn btn-outline">{btn.label}</a>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{sections.map(section => {
  if (section.type === 'hero') {
    return (
      <section class="ms-hero-card">
        <div class="container">
          <div class="hero-card">
            <div class="hero-card-copy">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              {section.ctaCheckout ? (
                <button type="button" class="btn btn-primary" data-checkout={section.ctaCheckout}>{section.ctaLabel}</button>
              ) : section.ctaHref ? (
                <a href={section.ctaHref} class="btn btn-primary">{section.ctaLabel}</a>
              ) : null}
            </div>
            {section.image && (
              <div class="hero-card-visual">
                <img src={section.image} alt="" loading="eager" />
              </div>
            )}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'quicknav' && section.items) {
    return (
      <section class="ms-quicknav section-sm">
        <div class="container">
          <div class="quicknav-grid">
            {section.items.map(q => (
              <a href={q.href} class="quicknav-item">
                <span class="quicknav-icon">{q.icon}</span>
                <span class="quicknav-label">{q.label}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'products' && section.cards) {
    return (
      <section class="section" id="products">
        <div class="container">
          <div class="products-grid">
            {section.cards.map(p => (
              <a href={p.href} class="ms-card">
                {p.image && <img src={p.image} alt="" class="ms-card-img" loading="lazy" />}
                <div class="ms-card-body">
                  <h3 class="ms-card-title">
                    {p.title}
                    {p.soon && <span class="soon-badge">Soon</span>}
                  </h3>
                  <p class="ms-card-desc">{p.description}</p>
                  {p.cta && <span class="ms-card-cta">{p.cta} →</span>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'feature') {
    return (
      <section class={`section ${section.greyBackground ? 'section-grey' : ''}`}>
        <div class="container">
          <div class="feature-banner">
            <div class="feature-banner-copy">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              {section.ctaHref && (
                <a href={section.ctaHref} class="btn btn-primary">{section.ctaLabel}</a>
              )}
            </div>
            {section.image && (
              <div class="feature-banner-img">
                <img src={section.image} alt="" loading="lazy" />
              </div>
            )}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'ai' && section.cards) {
    return (
      <section class="section">
        <div class="container">
          {section.heading && <h2 class="section-heading">{section.heading}</h2>}
          <div class="ai-grid">
            {section.cards.map(c => (
              <a href={c.href} class="ms-card ai-card">
                <div class="ms-card-body">
                  <h3 class="ms-card-title">{c.title}</h3>
                  <p class="ms-card-desc">{c.description}</p>
                  <span class="ms-card-cta">Learn more →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'why' && section.cards) {
    return (
      <section class={`section ${section.greyBackground ? 'section-grey' : ''}`}>
        <div class="container">
          {section.heading && <h2 class="section-heading">{section.heading}</h2>}
          <div class="why-grid">
            {section.cards.map(w => (
              <div class="why-card">
                <h3>{w.title}</h3>
                <p>{w.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  return null;
})}

<script>
document.querySelectorAll('.segment').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.segment').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });
});
</script>

<style>
.ms-greeting { padding: 2.5rem 0 1.5rem; text-align: center; }
.greeting-inner h1 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 0.35rem;
}
.greeting-sub { font-size: 0.9375rem; color: var(--text-muted); margin-bottom: 1.5rem; }
.segment-toggle {
  display: inline-flex;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px;
  margin-bottom: 1.25rem;
}
.segment {
  padding: 0.4rem 1.25rem;
  border: none;
  background: transparent;
  border-radius: var(--radius-pill);
  font-family: inherit;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
}
.segment.active { background: #fff; color: var(--text); box-shadow: var(--shadow-card); }
.greeting-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

.ms-hero-card { padding-bottom: 1rem; }
.hero-card {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 0;
  background: var(--navy-2);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 360px;
}
.hero-card-copy {
  padding: 3rem 3rem 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}
.hero-card-copy h2 {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 0.75rem;
}
.hero-card-copy p {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 420px;
}
.hero-card-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 1rem;
}
.hero-card-visual img {
  width: 100%;
  height: auto;
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}

.quicknav-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.5rem;
  text-align: center;
}
.quicknav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 0.5rem;
  border-radius: var(--radius-lg);
  transition: background var(--transition);
}
.quicknav-item:hover { background: var(--navy-2); }
.quicknav-icon { font-size: 1.5rem; }
.quicknav-label { font-size: 0.75rem; font-weight: 600; }

.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
}
.soon-badge {
  font-size: 0.65rem;
  font-weight: 700;
  color: #ca5010;
  background: #fff4ce;
  padding: 0.1rem 0.45rem;
  border-radius: var(--radius-pill);
  margin-left: 0.35rem;
  vertical-align: middle;
}

.feature-banner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 3rem;
  align-items: center;
  padding: 2rem 0;
}
.feature-banner-copy h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 600;
  margin-bottom: 0.75rem;
}
.feature-banner-copy p {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 480px;
}
.feature-banner-img img {
  width: 100%;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-hover);
}

.section-heading {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
}
.ai-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}
.ai-card { border: 1px solid var(--border); border-radius: var(--radius-lg); }

.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.why-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
}
.why-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
.why-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.55; }

@media (max-width: 1100px) {
  .products-grid { grid-template-columns: repeat(2, 1fr); }
  .quicknav-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .hero-card { grid-template-columns: 1fr; }
  .hero-card-visual { order: -1; min-height: 200px; }
  .hero-card-copy { padding: 2rem 1.5rem; }
  .feature-banner { grid-template-columns: 1fr; }
  .ai-grid, .why-grid { grid-template-columns: 1fr; }
  .products-grid { grid-template-columns: 1fr; }
  .quicknav-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
