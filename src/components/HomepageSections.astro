---
import type { HomepageData } from '../lib/cms-types';
import { getCollection } from 'astro:content';

interface Props {
  data: HomepageData;
}

const { data } = Astro.props;

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
const sections = data.sections.filter(s => s.enabled !== false);
---
{data.greeting && (
  <section class="ms-greeting">
    <div class="container greeting-inner">
      <h1>{data.greeting.headline}</h1>
      <p class="greeting-sub">{data.greeting.subheadline}</p>
      <div class="segment-toggle" role="navigation" aria-label="Product areas">
        <a href="/ats/" class="segment">Hiring and Recruiting</a>
        <a href="/comp/" class="segment">HR and Compensation</a>
      </div>
      {data.greeting.buttons?.length > 0 && (
        <div class="greeting-actions">
          {data.greeting.buttons.map(btn => (
            <a href={btn.href} class="btn btn-outline">{btn.label}</a>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{sections.map(section => {
  if (section.type === 'hero') {
    return (
      <section class={`ms-hero-card ${section.greyBackground ? 'section-grey' : ''}`}>
        <div class="container">
          <div class="hero-card">
            <div class="hero-card-copy">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              {section.ctaCheckout ? (
                <button type="button" class="btn btn-primary" data-checkout={section.ctaCheckout}>{section.ctaLabel}</button>
              ) : section.ctaHref ? (
                <a href={section.ctaHref} class="btn btn-primary">{section.ctaLabel}</a>
              ) : null}
            </div>
            {section.image && (
              <div class="hero-card-visual">
                <img src={section.image} alt="" loading="eager" />
              </div>
            )}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'quicknav' && section.items) {
    return (
      <section class="ms-quicknav section-sm">
        <div class="container">
          <div class="quicknav-grid">
            {section.items.map(q => (
              <a href={q.href} class="quicknav-item">
                <span class="quicknav-icon">{q.icon}</span>
                <span class="quicknav-label">{q.label}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'products' && section.cards) {
    return (
      <section class="section" id="products">
        <div class="container">
          <div class="products-grid">
            {section.cards.map(p => (
              <a href={p.href} class="ms-card">
                {p.image && <img src={p.image} alt="" class="ms-card-img" loading="lazy" />}
                <div class="ms-card-body">
                  <h3 class="ms-card-title">
                    {p.title}
                    {p.soon && <span class="soon-badge">Soon</span>}
                  </h3>
                  <p class="ms-card-desc">{p.description}</p>
                  {p.cta && <span class="ms-card-cta">{p.cta} →</span>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'feature') {
    return (
      <section class={`section ${section.greyBackground ? 'section-grey' : ''}`}>
        <div class="container">
          <div class="feature-banner">
            <div class="feature-banner-copy">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              {section.ctaHref && (
                <a href={section.ctaHref} class="btn btn-primary">{section.ctaLabel}</a>
              )}
            </div>
            {section.image && (
              <div class="feature-banner-img">
                <img src={section.image} alt="" loading="lazy" />
              </div>
            )}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'ai' && section.cards) {
    return (
      <section class="section">
        <div class="container">
          {section.heading && <h2 class="section-heading">{section.heading}</h2>}
          <div class="ai-grid">
            {section.cards.map(c => (
              <a href={c.href} class="ms-card ai-card">
                <div class="ms-card-body">
                  <h3 class="ms-card-title">{c.title}</h3>
                  <p class="ms-card-desc">{c.description}</p>
                  <span class="ms-card-cta">Learn more →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'why' && section.cards) {
    return (
      <section class={`section ${section.greyBackground ? 'section-grey' : ''}`}>
        <div class="container">
          {section.heading && <h2 class="section-heading">{section.heading}</h2>}
          <div class="why-grid">
            {section.cards.map(w => (
              <div class="why-card">
                <h3>{w.title}</h3>
                <p>{w.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'blog-posts') {
    return (
      <section class="section">
        <div class="container">
          <h2 class="section-heading">Latest from the blog</h2>
          <div class="blog-grid">
            {allPosts.map(post => {
              const d = post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
              return (
                <a href={`/blog/${post.slug}`} class="blog-card card">
                  <div class="blog-card-header">
                    {post.data.tags.slice(0, 1).map(t => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <div class="blog-card-footer">
                    <span class="blog-author">{post.data.author}</span>
                    <time>{d}</time>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    );
  }

  if (section.type === 'cmp-card') {
    return (
      <section class={`cmp-card-section ${section.greyBackground ? 'section-grey' : ''}`}>
        <div class="container">
          <div class="cmp-card-container">
            <div class="cmp-card-content">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              <a href="/comp/" class="cmp-pill-btn">Explore Kixlogic CMP</a>
            </div>
            <div class="cmp-card-form">
              <h3>Analyze a role</h3>
              <p class="cmp-field-label">Compensation model</p>
              <div class="cmp-models">
                <span class="cmp-model active">🌐 General</span>
                <span class="cmp-model">📋 Healthcare</span>
                <span class="cmp-model">🔵 Insurance</span>
                <span class="cmp-model">💼 Sales</span>
                <span class="cmp-model">🏠 Real Estate</span>
                <span class="cmp-model">🍽️ Restaurants</span>
              </div>
              <label class="cmp-field-label">Job title</label>
              <div class="cmp-input">e.g. Marketing Manager, Software Engineer</div>
              <div class="cmp-row">
                <div>
                  <label class="cmp-field-label">City</label>
                  <div class="cmp-input">e.g. Chicago</div>
                </div>
                <div>
                  <label class="cmp-field-label">State</label>
                  <div class="cmp-input">Select state</div>
                </div>
              </div>
              <div class="cmp-row">
                <div>
                  <label class="cmp-field-label">Experience</label>
                  <div class="cmp-input filled">3–5 years</div>
                </div>
                <div>
                  <label class="cmp-field-label">Company size</label>
                  <div class="cmp-input filled">11–50 employees</div>
                </div>
              </div>
              <button class="cmp-cta-mock">Try it free →</button>
            </div>
          </div>
        </div>
      </section>
    );
  }

  return null;
})}

<style>
.ms-greeting { padding: 2.5rem 0 1.5rem; text-align: center; }
.greeting-inner h1 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 0.35rem;
}
.greeting-sub { font-size: 0.9375rem; color: var(--text-muted); margin-bottom: 1.5rem; }
.segment-toggle {
  display: inline-flex;
  background: var(--navy-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 3px;
  margin-bottom: 1.25rem;
}
.segment {
  padding: 0.4rem 1.25rem;
  border: none;
  background: transparent;
  border-radius: var(--radius-pill);
  font-family: inherit;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--text-muted);
  text-decoration: none;
  transition: background var(--transition), color var(--transition), box-shadow var(--transition);
}
.segment:hover { color: var(--text); background: rgba(255,255,255,0.65); }
.segment.active { background: #fff; color: var(--text); box-shadow: var(--shadow-card); }
.greeting-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

.ms-hero-card { padding-bottom: 1rem; }
.ms-hero-card.section-grey { background: var(--navy-2); padding-top: 0.5rem; }
.hero-card {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 0;
  background: var(--navy-2);
  border-radius: var(--radius-lg);
  overflow: hidden;
  min-height: 360px;
}
.hero-card-copy {
  padding: 3rem 3rem 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}
.hero-card-copy h2 {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 0.75rem;
}
.hero-card-copy p {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 420px;
}
.hero-card-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 1rem;
}
.hero-card-visual img {
  width: 100%;
  height: auto;
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}

.quicknav-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.5rem;
  text-align: center;
}
.quicknav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 0.5rem;
  border-radius: var(--radius-lg);
  transition: background var(--transition);
}
.quicknav-item:hover { background: var(--navy-2); }
.quicknav-icon { font-size: 1.5rem; }
.quicknav-label { font-size: 0.75rem; font-weight: 600; }

.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
}
.soon-badge {
  font-size: 0.65rem;
  font-weight: 700;
  color: #ca5010;
  background: #fff4ce;
  padding: 0.1rem 0.45rem;
  border-radius: var(--radius-pill);
  margin-left: 0.35rem;
  vertical-align: middle;
}

.feature-banner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 3rem;
  align-items: center;
  padding: 2rem 0;
}
.feature-banner-copy h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 600;
  margin-bottom: 0.75rem;
}
.feature-banner-copy p {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 480px;
}
.feature-banner-img img {
  width: 100%;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-hover);
}

.section-heading {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
}
.ai-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}
.ai-card { border: 1px solid var(--border); border-radius: var(--radius-lg); }

.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.why-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
}
.why-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
.why-card p { font-size: 0.875rem; color: var(--text-muted); line-height: 1.55; }

@media (max-width: 1100px) {
  .products-grid { grid-template-columns: repeat(2, 1fr); }
  .quicknav-grid { grid-template-columns: repeat(3, 1fr); }
}
.section-heading {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
}
.blog-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.blog-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
}
.blog-card:hover {
  box-shadow: var(--shadow-hover);
}
.blog-card-header {
  margin-bottom: 0.5rem;
}
.blog-card h3 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  line-height: 1.4;
}
.blog-card p {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.55;
  margin-bottom: 1rem;
  flex: 1;
}
.blog-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.75rem;
  color: var(--text-dim);
}
.blog-author { font-weight: 600; }

.cmp-card-section {
  padding: 3rem 0;
  background: linear-gradient(160deg, #0b1f3f 0%, #102a54 55%, #0d2244 100%);
  color: #fff;
}
.cmp-pill-btn {
  display: inline-block;
  padding: 0.55rem 1.5rem;
  border-radius: 999px;
  background: #1db980;
  color: #fff;
  font-weight: 600;
  font-size: 0.875rem;
  text-decoration: none;
  margin-bottom: 1rem;
}
.cmp-pill-btn:hover { background: #17a06d; }
.cmp-card-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: center;
}
.cmp-card-content { color: #fff; }
.cmp-card-content h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 600;
  margin-bottom: 1rem;
  color: #fff;
}
.cmp-card-content p {
  font-size: 1rem;
  line-height: 1.65;
  color: rgba(255,255,255,0.82);
  max-width: 520px;
}
.cmp-card-form {
  background: #fff;
  border-radius: 8px;
  padding: 1.5rem;
  box-shadow: 0 20px 50px rgba(0,0,0,0.25);
}
.cmp-card-form h3 {
  font-size: 1.25rem;
  font-weight: 600;
  margin-bottom: 1rem;
}
.cmp-field-label {
  display: block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.35rem;
}
.cmp-models { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
.cmp-model {
  padding: 0.35rem 0.85rem;
  border-radius: 99px;
  background: #f3f4f6;
  color: var(--text-muted);
  font-size: 0.75rem;
  font-weight: 600;
}
.cmp-model.active { background: #d7f5e8; color: #0f6b4d; }
.cmp-input {
  border: 1px solid var(--border);
  background: #f9fafb;
  border-radius: 8px;
  padding: 0.65rem 0.75rem;
  font-size: 0.8125rem;
  color: #9ca3af;
  margin-bottom: 0.85rem;
}
.cmp-input.filled { color: var(--text); }
.cmp-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}
.cmp-cta-mock {
  width: 100%;
  margin-top: 0.5rem;
  background: #1db980;
  color: #fff;
  text-align: center;
  font-weight: 600;
  padding: 0.8rem;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  font-size: 0.9375rem;
}
.cmp-cta-mock:hover { background: #17a06d; }

@media (max-width: 768px) {
  .hero-card { grid-template-columns: 1fr; }
  .hero-card-visual { order: -1; min-height: 200px; }
  .hero-card-copy { padding: 2rem 1.5rem; }
  .feature-banner { grid-template-columns: 1fr; }
  .ai-grid, .why-grid { grid-template-columns: 1fr; }
  .products-grid { grid-template-columns: 1fr; }
  .quicknav-grid { grid-template-columns: repeat(2, 1fr); }
  .cmp-card-container { grid-template-columns: 1fr; }
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; }
}
</style>
