<style>
footer {
  border-top: 1px solid var(--border);
  padding: 3rem 0;
  position: relative;
  z-index: 1;
}
.footer-grid {
  display: grid;
  grid-template-columns: 1fr auto auto auto;
  gap: 3rem;
  align-items: start;
}
.footer-logo img { height: 60px; width: auto; }
.footer-copy { font-size: 0.8rem; color: var(--text-dim); margin-top: 0.35rem; }
.footer-legal {
  margin-top: 0.5rem;
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  align-items: center;
}
.footer-legal a {
  font-size: 0.75rem;
  color: var(--text-dim);
  transition: color var(--transition);
}
.footer-legal a:hover { color: var(--gold); }
.footer-legal span { color: var(--text-dim); font-size: 0.75rem; }
.footer-col-title {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-dim);
  margin-bottom: 0.75rem;
}
.footer-col { display: flex; flex-direction: column; gap: 0.5rem; }
.footer-link {
  font-size: 0.825rem;
  color: var(--text-dim);
  transition: color var(--transition);
  background: none;
  border: none;
  text-align: left;
  cursor: pointer;
}
.footer-link:hover { color: var(--gold); }
.footer-link-dot { display: flex; align-items: center; gap: 0.45rem; }
.dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.dot-teal { background: var(--gold); }
.dot-indigo { background: var(--indigo-light); }
.soon { font-size: 0.65rem; color: var(--text-dim); font-weight: 600; margin-left: 0.25rem; }
.footer-social { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }

@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
}
</style>
