---
import site from '../data/site.json';
import type { SiteData } from '../lib/cms-types';

const { promoBanner } = site as SiteData;
---
{promoBanner.enabled && (
  <div class="promo-banner">
    <div class="container promo-inner">
      <span>{promoBanner.text}</span>
      <a href={promoBanner.linkHref}>{promoBanner.linkLabel}</a>
    </div>
  </div>
)}

<style>
.promo-banner {
  background: var(--ms-blue);
  color: #fff;
  font-size: 0.8125rem;
  padding: 0.5rem 0;
  position: relative;
  z-index: 90;
}
.promo-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
  text-align: center;
}
.promo-inner a {
  color: #fff;
  font-weight: 600;
  text-decoration: underline;
  white-space: nowrap;
}
.promo-inner a:hover { opacity: 0.9; }
</style>
