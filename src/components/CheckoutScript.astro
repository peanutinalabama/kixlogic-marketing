
<script is:inline>
window.startCheckout = function(plan) {
  const planLabel = {
    starter: 'Starter — $49/mo',
    growth: 'Growth — $129/mo',
    professional: 'Professional — $249/mo',
    enterprise: 'Enterprise — Custom',
  }[plan] || plan;

  const existing = document.getElementById('checkoutModal');
  if (existing) existing.remove();

  const modal = document.createElement('div');
  modal.id = 'checkoutModal';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:9999;padding:1rem';
  modal.innerHTML = `
    <div style="background:#0f172a;border:1px solid rgba(20,184,148,0.3);border-radius:16px;padding:2rem;width:100%;max-width:420px;box-shadow:0 25px 60px rgba(0,0,0,0.5)">
      <div style="font-weight:800;font-size:1.1rem;color:#fff;margin-bottom:0.25rem">Get Started</div>
      <div style="font-size:0.82rem;color:#64748b;margin-bottom:1.5rem">${planLabel} · Cancel anytime</div>
      <input id="coEmail" type="email" placeholder="Work email address"
        style="width:100%;padding:0.75rem;background:#1e293b;border:1.5px solid #334155;border-radius:8px;font-size:0.9rem;color:#fff;outline:none;font-family:inherit;margin-bottom:0.75rem"/>
      <input id="coCompany" type="text" placeholder="Company name"
        style="width:100%;padding:0.75rem;background:#1e293b;border:1.5px solid #334155;border-radius:8px;font-size:0.9rem;color:#fff;outline:none;font-family:inherit;margin-bottom:1rem"/>
      <div id="coErr" style="color:#ef4444;font-size:0.8rem;margin-bottom:0.75rem;min-height:1rem"></div>
      <button id="coContinue"
        style="width:100%;padding:0.75rem;background:#14B894;color:#0a0a0a;border:none;border-radius:8px;font-weight:800;font-size:0.95rem;cursor:pointer;font-family:inherit">
        Continue to Payment →
      </button>
      <button id="coCancel"
        style="width:100%;padding:0.6rem;background:none;border:none;color:#475569;font-size:0.82rem;cursor:pointer;margin-top:0.5rem;font-family:inherit">
        Cancel
      </button>
      <div style="font-size:0.72rem;color:#475569;text-align:center;margin-top:0.75rem">🔒 Secured by Stripe</div>
    </div>`;
  document.body.appendChild(modal);
  document.getElementById('coEmail')?.focus();
  document.getElementById('coContinue')?.addEventListener('click', () => window.doCheckout(plan));
  document.getElementById('coCancel')?.addEventListener('click', () => modal.remove());
  modal.addEventListener('keydown', e => { if (e.key === 'Enter') window.doCheckout(plan); });
};

window.doCheckout = async function(plan) {
  const email   = (document.getElementById('coEmail')?.value || '').trim();
  const company = (document.getElementById('coCompany')?.value || '').trim();
  const errEl   = document.getElementById('coErr');
  const btn     = document.getElementById('coContinue');
  if (!email || !email.includes('@')) {
    if (errEl) errEl.textContent = 'Please enter a valid email address.';
    return;
  }
  if (btn) { btn.textContent = 'Redirecting to Stripe…'; btn.disabled = true; }
  if (errEl) errEl.textContent = '';
  try {
    const res = await fetch('https://api.kixlogic.com/api/stripe/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plan, email, companyName: company }),
    });
    const data = await res.json();
    if (data.url) { window.location.href = data.url; return; }
    if (errEl) errEl.textContent = data.error || 'Could not start checkout. Please try again.';
    if (btn) { btn.textContent = 'Continue to Payment →'; btn.disabled = false; }
  } catch {
    if (errEl) errEl.textContent = 'Connection error. Please try again.';
    if (btn) { btn.textContent = 'Continue to Payment →'; btn.disabled = false; }
  }
};

document.addEventListener('click', (e) => {
  const el = e.target.closest('[data-checkout]');
  if (el) window.startCheckout(el.getAttribute('data-checkout'));
});
</script>
